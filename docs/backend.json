
{
  "entities": {
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a registered business organization within the BizForge platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "licenseId": { "type": "string" },
        "ownerUserId": { "type": "string" },
        "ico": { "type": "string" },
        "enabledModuleIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email", "createdAt", "isActive", "ownerUserId"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an authenticated user account.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "globalRoles": { "type": "array", "items": { "type": "string" } },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "globalRoles", "createdAt"]
    },
    "License": {
      "title": "License",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "plan": { "type": "string", "enum": ["starter", "professional", "enterprise"] },
        "monthlyPrice": { "type": "number" },
        "usersLimit": { "type": "number" },
        "modulesEnabled": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "paymentProvider": { "type": "string", "enum": ["stripe", "gopay"] },
        "billingCycle": { "type": "string", "enum": ["monthly", "yearly"] },
        "lastPaymentDate": { "type": "string", "format": "date-time" },
        "nextPaymentDate": { "type": "string", "format": "date-time" },
        "paymentStatus": { "type": "string", "enum": ["active", "past_due", "unpaid", "canceled"] }
      }
    },
    "PlatformInvoice": {
      "title": "Platform Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "licenseId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid"] },
        "dueDate": { "type": "string", "format": "date" },
        "period": { "type": "string" }
      }
    },
    "Employee": {
      "title": "Employee",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "jobTitle": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "ico": { "type": "string" }
      }
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "customerId": { "type": "string" },
        "status": { "type": "string" },
        "budget": { "type": "number" },
        "assignedEmployeeIds": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Global user profiles."
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "entityName": "Company",
          "schema": { "$ref": "#/backend/entities/Company" },
          "description": "Organization details."
        }
      },
      {
        "path": "/licenses/{licenseId}",
        "definition": {
          "entityName": "License",
          "schema": { "$ref": "#/backend/entities/License" },
          "description": "Platform subscription plans."
        }
      },
      {
        "path": "/platform_invoices/{invoiceId}",
        "definition": {
          "entityName": "PlatformInvoice",
          "schema": { "$ref": "#/backend/entities/PlatformInvoice" },
          "description": "Invoices from BizForge to customer companies."
        }
      },
      {
        "path": "/companies/{companyId}/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": { "$ref": "#/backend/entities/Employee" },
          "description": "Employee profiles specific to a company."
        }
      },
      {
        "path": "/companies/{companyId}/customers/{customerId}",
        "definition": {
          "entityName": "Customer",
          "schema": { "$ref": "#/backend/entities/Customer" },
          "description": "Customer directory."
        }
      },
      {
        "path": "/companies/{companyId}/jobs/{jobId}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Job/project details specific to a company."
        }
      }
    ]
  }
}
