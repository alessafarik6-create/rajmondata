
{
  "entities": {
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a registered business organization within the BizForge platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "licenseId": { "type": "string" },
        "ownerUserId": { "type": "string" }
      },
      "required": ["id", "name", "email", "createdAt", "isActive", "ownerUserId"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an authenticated user account.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "globalRoles": { "type": "array", "items": { "type": "string" } },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "globalRoles", "createdAt"]
    },
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee profile within a specific company.",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "jobTitle": { "type": "string" },
        "role": { "type": "string" },
        "isActive": { "type": "boolean" },
        "hireDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "companyId", "firstName", "lastName", "email", "role", "isActive"]
    },
    "Job": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Job",
      "type": "object",
      "description": "Represents a job or project managed by a specific company.",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["nová", "rozpracovaná", "čeká", "dokončená", "fakturována"] 
        },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "budget": { "type": "number" },
        "assignedEmployeeIds": { "type": "array", "items": { "type": "string" } },
        "customerId": { "type": "string" }
      },
      "required": ["id", "companyId", "name", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Global user profiles."
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "entityName": "Company",
          "schema": { "$ref": "#/backend/entities/Company" },
          "description": "Organization details."
        }
      },
      {
        "path": "/companies/{companyId}/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": { "$ref": "#/backend/entities/Employee" },
          "description": "Employee profiles specific to a company."
        }
      },
      {
        "path": "/companies/{companyId}/jobs/{jobId}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Job/project details specific to a company."
        }
      }
    ]
  }
}
