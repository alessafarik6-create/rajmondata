
{
  "entities": {
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a registered business organization within the BizForge platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "licenseId": { "type": "string" },
        "ownerUserId": { "type": "string" }
      },
      "required": ["id", "name", "email", "createdAt", "isActive", "ownerUserId"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an authenticated user account.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "globalRoles": { "type": "array", "items": { "type": "string" } },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "globalRoles", "createdAt"]
    },
    "Employee": {
      "title": "Employee",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "jobTitle": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "ico": { "type": "string" }
      }
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "customerId": { "type": "string" },
        "status": { "type": "string" },
        "budget": { "type": "number" },
        "assignedEmployeeIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["received", "issued"] },
        "number": { "type": "string" },
        "entityName": { "type": "string", "description": "Supplier or Customer name" },
        "amount": { "type": "number" },
        "vat": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "issueDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "totalAmount": { "type": "number" },
        "vat": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid"] },
        "items": { "type": "array" }
      }
    },
    "FinancialRecord": {
      "title": "Financial Record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "type": { "type": "string", "enum": ["revenue", "expense"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Global user profiles."
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "entityName": "Company",
          "schema": { "$ref": "#/backend/entities/Company" },
          "description": "Organization details."
        }
      },
      {
        "path": "/companies/{companyId}/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": { "$ref": "#/backend/entities/Employee" },
          "description": "Employee profiles specific to a company."
        }
      },
      {
        "path": "/companies/{companyId}/customers/{customerId}",
        "definition": {
          "entityName": "Customer",
          "schema": { "$ref": "#/backend/entities/Customer" },
          "description": "Customer directory."
        }
      },
      {
        "path": "/companies/{companyId}/jobs/{jobId}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Job/project details specific to a company."
        }
      },
      {
        "path": "/companies/{companyId}/documents/{docId}",
        "definition": {
          "entityName": "Document",
          "schema": { "$ref": "#/backend/entities/Document" },
          "description": "Company business documents (received/issued)."
        }
      },
      {
        "path": "/companies/{companyId}/invoices/{invoiceId}",
        "definition": {
          "entityName": "Invoice",
          "schema": { "$ref": "#/backend/entities/Invoice" },
          "description": "Company invoices issued to customers."
        }
      },
      {
        "path": "/companies/{companyId}/finance/{recordId}",
        "definition": {
          "entityName": "FinancialRecord",
          "schema": { "$ref": "#/backend/entities/FinancialRecord" },
          "description": "Company financial transactions."
        }
      }
    ]
  }
}
