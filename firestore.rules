rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDoc() {
      return get(userPath()).data;
    }

    function hasUser() {
      return signedIn() && exists(userPath());
    }

    function userCompanyId() {
      return hasUser() ? userDoc().companyId : null;
    }

    function userRole() {
      return hasUser() ? userDoc().role : null;
    }

    function isPrivileged() {
      return userRole() in ['owner', 'admin', 'manager', 'accountant'];
    }

    /**
     * Zaměstnanec smí na dokumentu změnit pouze podpisová pole + status.
     * (Nesmí měnit title/type/fileUrl/storagePath/employeeId/companyId ani mazat.)
     */
    function employeeDocumentEmployeeUpdateAllowed() {
      return
        resource.data.companyId == request.resource.data.companyId &&
        resource.data.employeeId == request.resource.data.employeeId &&
        resource.data.title == request.resource.data.title &&
        resource.data.type == request.resource.data.type &&
        resource.data.fileUrl == request.resource.data.fileUrl &&
        resource.data.storagePath == request.resource.data.storagePath &&
        request.resource.data.status in [
          'draft','waiting_employee_signature','waiting_company_signature','signed_both'
        ] &&
        (!('employeeSignatureUrl' in request.resource.data) || request.resource.data.employeeSignatureUrl is string) &&
        (!('employeeSignedAt' in request.resource.data) || request.resource.data.employeeSignedAt is timestamp) &&
        (!('employeeSignedBy' in request.resource.data) || request.resource.data.employeeSignedBy is string) &&
        (!('finalSignedPdfUrl' in request.resource.data) || request.resource.data.finalSignedPdfUrl is string) &&
        (!('finalSignedStoragePath' in request.resource.data) || request.resource.data.finalSignedStoragePath is string);
    }

    /** Zákazník nesmí přepnout customer_activities na vyřízené; vedení může. */
    function customerActivityResolvedUnchanged() {
      let was = 'resolved' in resource.data && resource.data.resolved == true;
      let now = 'resolved' in request.resource.data && request.resource.data.resolved == true;
      return was == now;
    }

    /** Zaměstnanec může mazat jen vlastní blok ve stavu „čeká“ (nebo legacy bez reviewStatus). */
    function workBlockEmployeeCanSelfDelete() {
      return resource.data.authUserId == request.auth.uid &&
        (!('reviewStatus' in resource.data) ||
          resource.data.reviewStatus == 'pending' ||
          resource.data.reviewStatus == 'rejected');
    }

    function ownEmployeeId() {
      return hasUser() ? userDoc().employeeId : null;
    }

    function isSuperAdminFirebase() {
      return hasUser() &&
        'globalRoles' in userDoc() &&
        userDoc().globalRoles is list &&
        'super_admin' in userDoc().globalRoles;
    }

    /** Modul Sklad — zaměstnanec jen s canAccessWarehouse na svém profilu employees/{id}. */
    function employeeWarehouseFlag(companyId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(ownEmployeeId());
      return exists(empRef) &&
        'canAccessWarehouse' in get(empRef).data &&
        get(empRef).data.canAccessWarehouse == true;
    }

    /** Modul Výroba — zaměstnanec jen s canAccessProduction. */
    function employeeProductionFlag(companyId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(ownEmployeeId());
      return exists(empRef) &&
        'canAccessProduction' in get(empRef).data &&
        get(empRef).data.canAccessProduction == true;
    }

    /** Záznamy ze schůzek — běžný zaměstnanec jen s canAccessMeetingNotes (vedení vždy). */
    function employeeMeetingNotesFlag(companyId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(ownEmployeeId());
      return exists(empRef) &&
        'canAccessMeetingNotes' in get(empRef).data &&
        get(empRef).data.canAccessMeetingNotes == true;
    }

    function meetingRecordStaffRead(companyId) {
      return signedIn() && sameCompany(companyId) && userRole() != 'customer' && (
        isPrivileged() ||
        isSuperAdminFirebase() ||
        (userRole() == 'employee' && ownEmployeeId() != null && employeeMeetingNotesFlag(companyId))
      );
    }

    function meetingRecordStaffWrite(companyId) {
      return signedIn() && sameCompany(companyId) && userRole() != 'customer' && (
        userRole() in ['owner', 'admin', 'manager'] ||
        isSuperAdminFirebase() ||
        (userRole() == 'employee' && ownEmployeeId() != null && employeeMeetingNotesFlag(companyId))
      );
    }

    function meetingRecordIsSentToCustomerData(data) {
      return (('visibility' in data) && data.visibility is string && data.visibility == 'customer') ||
        (('isSharedWithCustomer' in data) && data.isSharedWithCustomer is bool && data.isSharedWithCustomer == true) ||
        (('sentToCustomer' in data) && data.sentToCustomer is bool && data.sentToCustomer == true) ||
        (('sharedWithCustomer' in data) && data.sharedWithCustomer is bool && data.sharedWithCustomer == true);
    }

    /** Při sdílení do portálu musí být CRM zákazník (i u zakázky). */
    function meetingRecordSharedNeedsCustomerId(data) {
      return !(('sharedWithCustomer' in data) && data.sharedWithCustomer is bool && data.sharedWithCustomer == true) ||
        (('customerId' in data) && data.customerId is string && data.customerId.size() > 0);
    }

    function meetingRecordHasTitleOrNotesData(data) {
      let mt = ('meetingTitle' in data) && data.meetingTitle is string && data.meetingTitle.size() > 0;
      let ti = ('title' in data) && data.title is string && data.title.size() > 0;
      let mn = ('meetingNotes' in data) && data.meetingNotes is string && data.meetingNotes.size() > 0;
      return mt || ti || mn;
    }

    function meetingRecordCustomerReadOk(companyId) {
      if (!(userRole() == 'customer' && sameCompany(companyId) && meetingRecordIsSentToCustomerData(resource.data))) {
        return false;
      }
      let hasJob = ('jobId' in resource.data) &&
        resource.data.jobId is string &&
        resource.data.jobId.size() > 0;
      if (hasJob) {
        return customerPortalLinkedJob(companyId, resource.data.jobId);
      }
      /** Obecný záznam bez zakázky — shoda CRM customerId s users.customerRecordId. */
      return 'customerRecordId' in userDoc() &&
        userDoc().customerRecordId is string &&
        userDoc().customerRecordId.size() > 0 &&
        'customerId' in resource.data &&
        resource.data.customerId is string &&
        resource.data.customerId.size() > 0 &&
        resource.data.customerId == userDoc().customerRecordId;
    }

    function meetingRecordCreateValid(companyId) {
      let d = request.resource.data;
      return d.companyId == companyId &&
        meetingRecordHasTitleOrNotesData(d) &&
        (!('title' in d) || (d.title is string && d.title.size() <= 500)) &&
        (!('meetingTitle' in d) || (d.meetingTitle is string && d.meetingTitle.size() <= 500)) &&
        d.meetingAt is timestamp &&
        d.meetingNotes is string && d.meetingNotes.size() <= 120000 &&
        d.sharedWithCustomer is bool &&
        (!('sentToCustomer' in d) || (d.sentToCustomer is bool && d.sentToCustomer == d.sharedWithCustomer)) &&
        (!('isSharedWithCustomer' in d) || (d.isSharedWithCustomer is bool && d.isSharedWithCustomer == d.sharedWithCustomer)) &&
        (!('visibility' in d) || (d.visibility is string && d.visibility in ['internal', 'customer'])) &&
        (!(('visibility' in d) && d.visibility == 'customer') || d.sharedWithCustomer == true) &&
        (!(('visibility' in d) && d.visibility == 'internal') || d.sharedWithCustomer == false) &&
        meetingRecordSharedNeedsCustomerId(d) &&
        d.createdBy == request.auth.uid &&
        (!('jobId' in d) || d.jobId == null || (d.jobId is string && d.jobId.size() > 0)) &&
        (!('shareHistory' in d) || d.shareHistory is list) &&
        (!('assignmentStatus' in d) || (d.assignmentStatus is string && d.assignmentStatus in ['assigned', 'unassigned'])) &&
        (!('sentToEmails' in d) || d.sentToEmails is list) &&
        (!('lastSentBy' in d) || (d.lastSentBy is string && d.lastSentBy.size() <= 128)) &&
        (!('sentAt' in d) || d.sentAt is timestamp);
    }

    function meetingRecordUpdateValid(companyId) {
      let d = request.resource.data;
      return d.companyId == companyId &&
        meetingRecordHasTitleOrNotesData(d) &&
        (!('title' in d) || (d.title is string && d.title.size() <= 500)) &&
        (!('meetingTitle' in d) || (d.meetingTitle is string && d.meetingTitle.size() <= 500)) &&
        d.meetingNotes is string && d.meetingNotes.size() <= 120000 &&
        d.sharedWithCustomer is bool &&
        (!('sentToCustomer' in d) || (d.sentToCustomer is bool && d.sentToCustomer == d.sharedWithCustomer)) &&
        (!('isSharedWithCustomer' in d) || (d.isSharedWithCustomer is bool && d.isSharedWithCustomer == d.sharedWithCustomer)) &&
        (!('visibility' in d) || (d.visibility is string && d.visibility in ['internal', 'customer'])) &&
        (!(('visibility' in d) && d.visibility == 'customer') || d.sharedWithCustomer == true) &&
        (!(('visibility' in d) && d.visibility == 'internal') || d.sharedWithCustomer == false) &&
        meetingRecordSharedNeedsCustomerId(d) &&
        (!('jobId' in d) || d.jobId == null || (d.jobId is string && d.jobId.size() > 0)) &&
        (!('shareHistory' in d) || d.shareHistory is list) &&
        (!('assignmentStatus' in d) || (d.assignmentStatus is string && d.assignmentStatus in ['assigned', 'unassigned'])) &&
        (!('sentToEmails' in d) || d.sentToEmails is list) &&
        (!('lastSentBy' in d) || (d.lastSentBy is string && d.lastSentBy.size() <= 128)) &&
        (!('sentAt' in d) || d.sentAt is timestamp);
    }

    function warehouseModuleUser(companyId) {
      return signedIn() && sameCompany(companyId) && (
        userRole() in ['owner', 'admin', 'manager'] ||
        (userRole() == 'employee' && ownEmployeeId() != null && employeeWarehouseFlag(companyId)) ||
        isSuperAdminFirebase()
      );
    }

    /**
     * Správa kategorií skladu — zarovnáno na portál (vlastník / admin / manažer; ne běžný zaměstnanec jen se skladem).
     * Dříve jen isPrivileged() — účetní apod. nepotřebuje kategorie; důležité je shodit s `warehouseModuleUser` pro vedení.
     */
    function warehouseInventoryManager(companyId) {
      return signedIn() && sameCompany(companyId) && (
        userRole() in ['owner', 'admin', 'manager'] ||
        isSuperAdminFirebase()
      );
    }

    function stockCategoryCreateValid(companyId) {
      let d = request.resource.data;
      return d.companyId == companyId &&
        d.name is string && d.name.size() > 0 && d.name.size() <= 200 &&
        d.order is int &&
        d.createdBy == request.auth.uid;
    }

    function stockCategoryUpdateValid(companyId) {
      let d = request.resource.data;
      let r = resource.data;
      return d.companyId == companyId &&
        r.companyId == companyId &&
        d.name is string && d.name.size() > 0 && d.name.size() <= 200;
    }

    function productionModuleUser(companyId) {
      return signedIn() && sameCompany(companyId) && (
        userRole() in ['owner', 'admin', 'manager'] ||
        (userRole() == 'employee' && ownEmployeeId() != null && employeeProductionFlag(companyId)) ||
        isSuperAdminFirebase()
      );
    }

    function sameCompany(companyId) {
      return hasUser() && userCompanyId() == companyId;
    }

    /** Firemní doklad s evidovanou částkou (ne čistá fotodokumentace bez částky). */
    function companyDocumentHasFinancialAmount(data) {
      return ('castka' in data && data.castka is number && data.castka > 0) ||
        ('amountNet' in data && data.amountNet is number && data.amountNet > 0) ||
        ('amountGross' in data && data.amountGross is number && data.amountGross > 0) ||
        ('amount' in data && data.amount is number && data.amount > 0);
    }

    /** Zrcadlo z médií zakázky nebo nákladů (může nemít vlastní částku jako fotky). */
    function companyDocumentIsSyncedMirror(data) {
      return ('source' in data && data.source == 'job-media') ||
        ('source' in data && data.source == 'job-expense');
    }

    /** Dodací list bez částky (nový typ v sekci Doklady). */
    function companyDocumentIsDeliveryNote(data) {
      return ('documentType' in data && data.documentType == 'delivery_note') ||
        ('type' in data && data.type == 'delivery_note') ||
        ('documentKind' in data && data.documentKind == 'delivery_note');
    }

    /**
     * První vytvoření firmy při registraci (batch ještě neobsahuje users/{uid}, takže sameCompany nejde použít).
     * Dokument musí mít vlastníka = aktuální uživatel.
     */
    function isNewCompanyOwnedByRequester() {
      return signedIn() &&
        request.resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.ownerId == request.auth.uid;
    }

    /** Zaměstnanec (ne vlastník/admin/manažer/účetní) může zapisovat vlastní výkaz práce. */
    function canLogOwnWorkTime() {
      return hasUser() && ownEmployeeId() != null && !isPrivileged();
    }

    /** Zakázka pro výkaz práce — assignedWorklogJobIds nebo legacy assignedJobIds. */
    function jobAssignedForWorklog(companyId, jobId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(ownEmployeeId());
      return exists(empRef) && (
        ('assignedWorklogJobIds' in get(empRef).data && jobId in get(empRef).data.assignedWorklogJobIds) ||
        ('assignedJobIds' in get(empRef).data && jobId in get(empRef).data.assignedJobIds)
      );
    }

    /** Alias pro starší název v pravidlech create výkazu. */
    function jobAssignedToEmployee(companyId, jobId) {
      return jobAssignedForWorklog(companyId, jobId);
    }

    /** Zakázka pro docházkový terminál (vlastní zaměstnanec). */
    function jobAssignedForTerminal(companyId, jobId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(ownEmployeeId());
      return exists(empRef) &&
        'assignedTerminalJobIds' in get(empRef).data &&
        jobId in get(empRef).data.assignedTerminalJobIds;
    }

    function jobAssignedForTerminalToEmployee(companyId, empId, jobId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(empId);
      return exists(empRef) &&
        'assignedTerminalJobIds' in get(empRef).data &&
        jobId in get(empRef).data.assignedTerminalJobIds;
    }

    /** Zakázka přiřazená pro výrobu / montáž (pole na dokumentu zakázky). */
    function jobAssignedForProduction(companyId, jobId) {
      let jobPath = /databases/$(database)/documents/companies/$(companyId)/jobs/$(jobId);
      return ownEmployeeId() != null &&
        exists(jobPath) &&
        'productionAssignedEmployeeIds' in get(jobPath).data &&
        get(jobPath).data.productionAssignedEmployeeIds is list &&
        ownEmployeeId() in get(jobPath).data.productionAssignedEmployeeIds;
    }

    /** Čtení skladu pro výdej ve výrobě — zaměstnanec s moduly Sklad nebo Výroba. */
    function inventoryReadForProductionOrWarehouse(companyId) {
      return signedIn() && sameCompany(companyId) && (
        warehouseModuleUser(companyId) ||
        (
          userRole() == 'employee' &&
          ownEmployeeId() != null &&
          employeeProductionFlag(companyId)
        ) ||
        isSuperAdminFirebase()
      );
    }

    /** Složka zakázky viditelná výrobnímu týmu (mimo typ documents). */
    function folderDocProductionTeamVisible(companyId, jobId, folderId) {
      let fp = /databases/$(database)/documents/companies/$(companyId)/jobs/$(jobId)/folders/$(folderId);
      let jp = /databases/$(database)/documents/companies/$(companyId)/jobs/$(jobId);
      return exists(fp) && exists(jp) &&
        get(fp).data.type != 'documents' &&
        (
          ('productionTeamVisible' in get(fp).data && get(fp).data.productionTeamVisible == true) ||
          (
            'productionVisibleFolderIds' in get(jp).data &&
            get(jp).data.productionVisibleFolderIds is list &&
            folderId in get(jp).data.productionVisibleFolderIds
          )
        );
    }

    function jobProductionMediaReader(companyId, jobId) {
      return signedIn() && sameCompany(companyId) &&
        userRole() == 'employee' &&
        ownEmployeeId() != null &&
        employeeProductionFlag(companyId) &&
        jobAssignedForProduction(companyId, jobId);
    }

    /** Přístup člena zakázky — documents/.../jobs/{jobId}/jobMembers/{employeeId} */
    function jobMemberPathForEmp(companyId, jobId, memberEmpId) {
      return /databases/$(database)/documents/companies/$(companyId)/jobs/$(jobId)/jobMembers/$(memberEmpId);
    }

    function hasJobMemberDocForSelf(companyId, jobId) {
      return ownEmployeeId() != null &&
        exists(jobMemberPathForEmp(companyId, jobId, ownEmployeeId()));
    }

    function jobMemberFullInternal(companyId, jobId) {
      return hasJobMemberDocForSelf(companyId, jobId) &&
        get(jobMemberPathForEmp(companyId, jobId, ownEmployeeId())).data.accessMode == 'full_internal';
    }

    /** Zaměstnanec portálu s přiřazením k zakázce (výkaz / terminál / explicitní jobMembers). */
    function jobPortalEmployeeEligible(companyId, jobId) {
      return signedIn() && sameCompany(companyId) &&
        userRole() == 'employee' &&
        ownEmployeeId() != null && (
          hasJobMemberDocForSelf(companyId, jobId) ||
          jobAssignedForWorklog(companyId, jobId) ||
          jobAssignedForTerminal(companyId, jobId)
        );
    }

    /** Omezený režim: vidí jen employeeSummary + employeeVisible složky / soubory. */
    function jobEmployeeLimitedMediaProfile(companyId, jobId) {
      return jobPortalEmployeeEligible(companyId, jobId) &&
        !jobMemberFullInternal(companyId, jobId) &&
        !isPrivileged();
    }

    /** Finance, doklady, plné dokumenty — jen administrace nebo full_internal na zakázce. */
    function jobFinancialReadAccess(companyId, jobId) {
      return signedIn() && sameCompany(companyId) &&
        (isPrivileged() || jobMemberFullInternal(companyId, jobId));
    }

    function jobEmployeeMustUseSummaryOnly(companyId, jobId) {
      return jobEmployeeLimitedMediaProfile(companyId, jobId);
    }

    function folderDocEmployeeVisible(companyId, jobId, folderId) {
      let fp = /databases/$(database)/documents/companies/$(companyId)/jobs/$(jobId)/folders/$(folderId);
      return exists(fp) && (
        get(fp).data.employeeVisible == true ||
        get(fp).data.employeeVisibility == 'employee_visible'
      );
    }

    function folderDocEmployeeUploadAllowed(companyId, jobId, folderId) {
      let fp = /databases/$(database)/documents/companies/$(companyId)/jobs/$(jobId)/folders/$(folderId);
      return exists(fp) && (
        get(fp).data.allowEmployeeUpload == true ||
        /** Legacy (zpětná kompatibilita) */
        get(fp).data.employeeUploadAllowed == true
      );
    }

    function legacyJobPhotosEmployeeAllowed(companyId, jobId) {
      let sp = /databases/$(database)/documents/companies/$(companyId)/jobs/$(jobId)/employeeSummary/summary;
      return exists(sp) && get(sp).data.legacyPhotosEmployeeVisible == true;
    }

    /** Čtení detailu zakázky včetně fotek / složek (shodně s dokumentem jobs/{jobId}). */
    function jobDetailReadAccess(companyId, jobId) {
      return terminalCompanyMatches(companyId) ||
        (signedIn() && sameCompany(companyId) &&
          (isPrivileged() ||
            (canLogOwnWorkTime() &&
              (jobAssignedForWorklog(companyId, jobId) ||
                jobAssignedForTerminal(companyId, jobId)))));
    }

    /** Klientský portál — uživatel má zakázku v users.linkedJobIds (stejná logika jako ve frontendu). */
    function customerPortalLinkedJob(companyId, jobId) {
      return signedIn() && sameCompany(companyId) && userRole() == 'customer' &&
        'linkedJobIds' in userDoc() && userDoc().linkedJobIds is list &&
        jobId in userDoc().linkedJobIds;
    }

    /** Složka viditelná zákazníkovi (klientský portál) — nesmí být interní ani účetní. */
    function jobFolderDocCustomerPortalVisible(companyId, jobId, folderId) {
      let fp = /databases/$(database)/documents/companies/$(companyId)/jobs/$(jobId)/folders/$(folderId);
      return exists(fp) &&
        (!(get(fp).data.internalOnly is bool) || get(fp).data.internalOnly != true) &&
        get(fp).data.customerVisible == true &&
        get(fp).data.type != 'documents';
    }

    /** Legacy foto / obrázek ve složce — zákazník smí číst. */
    function jobMediaCustomerPortalImageReadOk(companyId, jobId, folderId) {
      return customerPortalLinkedJob(companyId, jobId) &&
        jobFolderDocCustomerPortalVisible(companyId, jobId, folderId) &&
        (!(resource.data.internalOnly is bool) || resource.data.internalOnly != true) &&
        (!(resource.data.customerVisible is bool) || resource.data.customerVisible != false);
    }

    function jobLegacyPhotoCustomerPortalReadOk() {
      return resource.data.customerVisible == true &&
        (!(resource.data.internalOnly is bool) || resource.data.internalOnly != true);
    }

    /** Zákazník může zapsat jen odpověď ke schválení konkrétního souboru. */
    function jobFolderImageCustomerApprovalUpdateOk() {
      let d = request.resource.data;
      let r = resource.data;
      return r.requiresCustomerApproval == true &&
        d.requiresCustomerApproval == true &&
        d.companyId == r.companyId &&
        d.jobId == r.jobId &&
        d.folderId == r.folderId &&
        d.createdBy == r.createdBy &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'approvalStatus', 'approvedAt', 'approvedBy',
          'customerComment', 'customerCommentAt', 'customerCommentBy'
        ]) &&
        d.approvalStatus in ['approved', 'changes_requested'] &&
        (d.approvalStatus != 'approved' ||
          (d.approvedBy == request.auth.uid && d.approvedAt is timestamp)) &&
        (d.approvalStatus != 'changes_requested' ||
          (d.customerComment is string && d.customerComment.size() > 0 && d.customerComment.size() <= 8000 &&
            d.customerCommentBy == request.auth.uid && d.customerCommentAt is timestamp));
    }

    function jobLegacyPhotoCustomerApprovalUpdateOk() {
      let d = request.resource.data;
      let r = resource.data;
      return r.requiresCustomerApproval == true &&
        d.requiresCustomerApproval == true &&
        d.companyId == r.companyId &&
        d.jobId == r.jobId &&
        d.createdBy == r.createdBy &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'approvalStatus', 'approvedAt', 'approvedBy',
          'customerComment', 'customerCommentAt', 'customerCommentBy'
        ]) &&
        d.approvalStatus in ['approved', 'changes_requested'] &&
        (d.approvalStatus != 'approved' ||
          (d.approvedBy == request.auth.uid && d.approvedAt is timestamp)) &&
        (d.approvalStatus != 'changes_requested' ||
          (d.customerComment is string && d.customerComment.size() > 0 && d.customerComment.size() <= 8000 &&
            d.customerCommentBy == request.auth.uid && d.customerCommentAt is timestamp));
    }

    /** Vrstvy anotací zákazníka / firmy u média zakázky — validace zápisu. */
    function jobDocumentAnnotationPayloadOk() {
      return request.resource.data.keys().hasAll(
          ['companyId', 'jobId', 'documentId', 'type', 'data', 'visibleFor', 'updatedBy', 'mediaKind']) &&
        request.resource.data.companyId is string &&
        request.resource.data.jobId is string &&
        request.resource.data.documentId is string &&
        request.resource.data.documentId.size() > 0 &&
        request.resource.data.documentId.size() <= 400 &&
        request.resource.data.type == 'customer_overlay' &&
        request.resource.data.updatedBy == request.auth.uid &&
        request.resource.data.mediaKind in ['image', 'pdf'] &&
        request.resource.data.data is map &&
        request.resource.data.visibleFor is list;
    }

    /** Volitelná pole schválení / připomínky zákazníka u document_annotations. */
    function jobDocumentAnnotationReviewFieldsOk() {
      let d = request.resource.data;
      if (!('reviewStatus' in d) && !('customerComment' in d) &&
          !('customerCommentAt' in d) && !('customerCommentBy' in d)) {
        return true;
      }
      if ('reviewStatus' in d) {
        if (!(d.reviewStatus in ['pending', 'approved', 'commented'])) {
          return false;
        }
      }
      if ('customerComment' in d) {
        if (!(d.customerComment is string) || d.customerComment.size() > 8000) {
          return false;
        }
      }
      if ('customerCommentAt' in d && d.customerCommentAt != null) {
        if (!(d.customerCommentAt is timestamp)) {
          return false;
        }
      }
      if ('customerCommentBy' in d) {
        if (!(d.customerCommentBy is string) ||
            d.customerCommentBy.size() < 1 || d.customerCommentBy.size() > 128) {
          return false;
        }
      }
      if ('reviewStatus' in d && d.reviewStatus == 'commented') {
        if (!('customerComment' in d) || d.customerComment.size() < 1) {
          return false;
        }
        if (!('customerCommentAt' in d) || d.customerCommentAt == null) {
          return false;
        }
        if (!('customerCommentBy' in d) || d.customerCommentBy != request.auth.uid) {
          return false;
        }
      }
      return true;
    }

    /** Pokud je u docházky vyplněno jobId, musí být přiřazeno pro terminál danému zaměstnanci. */
    function attendanceJobValid(companyId) {
      return !('jobId' in request.resource.data) ||
        request.resource.data.jobId == null ||
        (request.resource.data.jobId is string && request.resource.data.jobId.size() > 0 &&
          jobAssignedForTerminalToEmployee(companyId, request.resource.data.employeeId, request.resource.data.jobId));
    }

    function workBlockOwnPending() {
      return resource.data.employeeId == ownEmployeeId() &&
        resource.data.authUserId == request.auth.uid &&
        (resource.data.reviewStatus == 'pending' || resource.data.reviewStatus == 'rejected');
    }

    /** Úprava výkazu zaměstnancem — nesmí měnit schvalovací pole; zakázka musí být přiřazená. */
    function employeeWorkBlockUpdateValid(companyId) {
      return request.resource.data.employeeId == resource.data.employeeId &&
        request.resource.data.authUserId == resource.data.authUserId &&
        request.resource.data.companyId == resource.data.companyId &&
        request.resource.data.reviewStatus == resource.data.reviewStatus &&
        request.resource.data.jobId is string &&
        jobAssignedForWorklog(companyId, request.resource.data.jobId) &&
        request.resource.data.adminNote == resource.data.adminNote &&
        request.resource.data.adjustmentReason == resource.data.adjustmentReason &&
        (!('reviewedBy' in resource.data) ||
          request.resource.data.reviewedBy == resource.data.reviewedBy) &&
        (!('reviewedAt' in resource.data) ||
          request.resource.data.reviewedAt == resource.data.reviewedAt) &&
        (
          (!('description_translated' in request.resource.data) && !('description_translated' in resource.data)) ||
          request.resource.data.description_translated == resource.data.description_translated
        ) &&
        (!('attendanceSegmentId' in resource.data) ||
          request.resource.data.attendanceSegmentId == resource.data.attendanceSegmentId);
    }

    /** Kiosk terminál po custom tokenu (claim terminalAccess + companyId). */
    function terminalCompanyMatches(companyId) {
      return request.auth != null &&
        request.auth.token.terminalAccess == true &&
        request.auth.token.companyId == companyId;
    }

    // --- Uživatelské profily (klientská aplikace) ---
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;

      match /{subcollection}/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    // --- Firma ---
    match /companies/{companyId} {
      allow read: if (signedIn() && sameCompany(companyId)) || terminalCompanyMatches(companyId);
      allow create: if isNewCompanyOwnedByRequester();
      allow update, delete: if signedIn() && sameCompany(companyId) && isPrivileged();

      match /employees/{empId} {
        allow read: if (signedIn() && sameCompany(companyId)) || terminalCompanyMatches(companyId);
        allow write: if signedIn() && sameCompany(companyId) && isPrivileged();

        /** Hash PINu terminálu — pouze Admin SDK / API (klient nesmí číst ani zapisovat). */
        match /private/{docId} {
          allow read, write: if false;
        }

        /**
         * Dokumenty zaměstnance:
         * companies/{companyId}/employees/{employeeId}/documents/{documentId}
         */
        match /documents/{documentId} {
          allow read: if signedIn() && sameCompany(companyId) && (
            isPrivileged() || empId == ownEmployeeId()
          );
          allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            request.resource.data.companyId == companyId &&
            request.resource.data.employeeId == empId &&
            request.resource.data.title is string &&
            request.resource.data.title.size() > 0 &&
            request.resource.data.title.size() <= 200 &&
            request.resource.data.type in [
              'employment_contract','dpp','dpc','agreement_other','addendum','personal_id','photo','other'
            ] &&
            request.resource.data.fileUrl is string &&
            request.resource.data.storagePath is string &&
            request.resource.data.status in [
              'draft','waiting_employee_signature','waiting_company_signature','signed_both'
            ];
          allow update: if signedIn() && sameCompany(companyId) && (
            isPrivileged() ||
            /** zaměstnanec smí podepsat pouze svůj dokument */
            (empId == ownEmployeeId() && employeeDocumentEmployeeUpdateAllowed())
          );
          allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
        }
      }

      /**
       * Šablony zaměstnaneckých dokumentů:
       * companies/{companyId}/employeeDocumentTemplates/{templateId}
       */
      match /employeeDocumentTemplates/{templateId} {
        allow read: if signedIn() && sameCompany(companyId) && isPrivileged();
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.title.size() <= 200 &&
          request.resource.data.type in ['employment_contract','dpp','dpc','agreement_other'] &&
          request.resource.data.content is string &&
          request.resource.data.content.size() > 0 &&
          request.resource.data.content.size() <= 200000;
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          resource.data.companyId == companyId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.title is string &&
          request.resource.data.type in ['employment_contract','dpp','dpc','agreement_other'] &&
          request.resource.data.content is string;
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /** Sklad — položky a pohyby */
      match /inventoryItems/{itemId} {
        allow read: if inventoryReadForProductionOrWarehouse(companyId);
        allow write: if warehouseModuleUser(companyId);
      }

      /** Kategorie skladových položek (správa ve skladu). */
      match /stockCategories/{categoryId} {
        allow read: if inventoryReadForProductionOrWarehouse(companyId);
        allow create: if warehouseInventoryManager(companyId) && stockCategoryCreateValid(companyId);
        allow update: if warehouseInventoryManager(companyId) && stockCategoryUpdateValid(companyId);
        allow delete: if warehouseInventoryManager(companyId);
      }

      /**
       * Produktové katalogy pro zákazníky.
       * companies/{companyId}/product_catalogs/{catalogId}
       */
      match /product_catalogs/{catalogId} {
        allow read: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          (
            userRole() == 'customer' &&
            ('customerVisible' in resource.data) && resource.data.customerVisible == true &&
            ('active' in resource.data) && resource.data.active == true &&
            ('assignedJobIds' in resource.data) &&
            resource.data.assignedJobIds is list &&
            ('linkedJobIds' in userDoc()) &&
            userDoc().linkedJobIds is list &&
            resource.data.assignedJobIds.hasAny(userDoc().linkedJobIds)
          )
        );
        allow create, update, delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      match /inventoryMovements/{movId} {
        allow read: if inventoryReadForProductionOrWarehouse(companyId);
        allow write: if warehouseModuleUser(companyId);
      }

      /**
       * Aktivity zákazníků pro dashboard vedení.
       * companies/{companyId}/customer_activities/{activityId}
       */
      match /customer_activities/{activityId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || userRole() == 'manager' || userRole() == 'accountant');
        allow create: if signedIn() && sameCompany(companyId) && (
          isPrivileged() || userRole() == 'customer'
        );
        allow update: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          (
            request.resource.data.createdBy == resource.data.createdBy &&
            request.resource.data.createdByRole == resource.data.createdByRole &&
            request.resource.data.isRead == resource.data.isRead &&
            customerActivityResolvedUnchanged()
          )
        );
        allow delete: if false;
      }

      /**
       * Aktivity zaměstnanců pro dashboard (zápis přes Admin SDK).
       * companies/{companyId}/employee_activities/{activityId}
       */
      match /employee_activities/{activityId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || userRole() == 'manager' || userRole() == 'accountant');
        allow create: if false;
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged();
        allow delete: if false;
      }

      /**
       * Upozornění zaměstnancům (např. z kalendáře).
       * companies/{companyId}/employee_notifications/{notificationId}
       *
       * - zápis hromadných upozornění: jen privileged role
       * - zaměstnanec: může číst své a označit jako přečtené
       */
      match /employee_notifications/{notificationId} {
        allow read: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          (
            userRole() == 'employee' &&
            (
              resource.data.employeeId == request.auth.uid ||
              (('employeeId' in userDoc()) && resource.data.employeeId == userDoc().employeeId)
            )
          )
        );

        allow create, delete: if signedIn() && sameCompany(companyId) && isPrivileged();

        allow update: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          (
            userRole() == 'employee' &&
            (
              resource.data.employeeId == request.auth.uid ||
              (('employeeId' in userDoc()) && resource.data.employeeId == userDoc().employeeId)
            ) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead', 'readAt', 'updatedAt']) &&
            request.resource.data.isRead == true
          )
        );
      }

      /**
       * Zákaznický chat s administrací.
       * companies/{companyId}/customer_conversations/{conversationId}
       */
      match /customer_conversations/{conversationId} {
        allow read: if signedIn() && sameCompany(companyId) && (
          isPrivileged() || resource.data.customerUserId == request.auth.uid
        );
        allow create, update: if signedIn() && sameCompany(companyId) && (
          isPrivileged() || request.resource.data.customerUserId == request.auth.uid
        );
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();

        match /messages/{messageId} {
          allow read: if signedIn() && sameCompany(companyId) && (
            isPrivileged() || get(/databases/$(database)/documents/companies/$(companyId)/customer_conversations/$(conversationId)).data.customerUserId == request.auth.uid
          );
          allow create: if signedIn() && sameCompany(companyId) && (
            isPrivileged() ||
            (
              request.resource.data.senderId == request.auth.uid &&
              request.resource.data.senderRole == 'customer' &&
              get(/databases/$(database)/documents/companies/$(companyId)/customer_conversations/$(conversationId)).data.customerUserId == request.auth.uid
            )
          );
          allow update: if signedIn() && sameCompany(companyId) && isPrivileged();
          allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
        }
      }

      /** Výroba — záznamy a přílohy (sklad může dopisovat materiál při přesunu ze skladu). */
      match /production/{prodId} {
        allow read, write: if productionModuleUser(companyId) || warehouseModuleUser(companyId);

        match /attachments/{attId} {
          allow read, write: if productionModuleUser(companyId) || warehouseModuleUser(companyId);
        }
      }

      match /work_time_blocks/{bid} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() ||
            (canLogOwnWorkTime() && resource.data.employeeId == ownEmployeeId()));
        allow create: if signedIn() && sameCompany(companyId) &&
          canLogOwnWorkTime() &&
          request.resource.data.authUserId == request.auth.uid &&
          request.resource.data.employeeId == ownEmployeeId() &&
          request.resource.data.jobId is string &&
          request.resource.data.jobId.size() > 0 &&
          jobAssignedToEmployee(companyId, request.resource.data.jobId) &&
          request.resource.data.reviewStatus == 'pending' &&
          (!('description_translated' in request.resource.data) ||
            request.resource.data.description_translated == null) &&
          (!('language' in request.resource.data) ||
            request.resource.data.language in ['cs', 'ua']) &&
          (!('attendanceSegmentId' in request.resource.data) ||
            (request.resource.data.attendanceSegmentId is string &&
              request.resource.data.attendanceSegmentId.size() > 0));
        allow update: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          (canLogOwnWorkTime() && workBlockOwnPending() && employeeWorkBlockUpdateValid(companyId))
        );
        allow delete: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || workBlockEmployeeCanSelfDelete());
      }

      /**
       * Denní výkazy práce — zápis přes Admin API; klient jen čte.
       * companies/{companyId}/daily_work_reports/{docId}
       */
      match /daily_work_reports/{reportId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId());
        allow write: if false;
      }

      /**
       * Označení denní výplaty (zaplaceno / poznámka) — admin zapisuje, zaměstnanec čte vlastní.
       * companies/{companyId}/employee_day_payouts/{docId}
       */
      match /employee_day_payouts/{payoutId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId());
        allow create, update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId is string &&
          request.resource.data.employeeId.size() > 0 &&
          request.resource.data.date is string &&
          request.resource.data.date.size() == 10 &&
          request.resource.data.paid is bool &&
          (!('paidNote' in request.resource.data) ||
            request.resource.data.paidNote == null ||
            (request.resource.data.paidNote is string &&
              request.resource.data.paidNote.size() <= 400)) &&
          (!('approved' in request.resource.data) ||
            request.resource.data.approved is bool) &&
          (!('approvedAt' in request.resource.data) ||
            request.resource.data.approvedAt == null ||
            request.resource.data.approvedAt is timestamp) &&
          (!('approvedBy' in request.resource.data) ||
            request.resource.data.approvedBy == null ||
            (request.resource.data.approvedBy is string &&
              request.resource.data.approvedBy.size() > 0)) &&
          (!('paidAt' in request.resource.data) ||
            request.resource.data.paidAt == null ||
            request.resource.data.paidAt is timestamp) &&
          (!('paidBy' in request.resource.data) ||
            request.resource.data.paidBy == null ||
            (request.resource.data.paidBy is string &&
              request.resource.data.paidBy.size() > 0));
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /**
       * Záznamy ze schůzek — veřejná část v dokumentu; interní poznámky v meetingRecords/{id}/internal/data.
       */
      match /meetingRecords/{meetingId} {
        allow read: if meetingRecordStaffRead(companyId) || meetingRecordCustomerReadOk(companyId);
        allow create: if meetingRecordStaffWrite(companyId) && meetingRecordCreateValid(companyId);
        allow update: if meetingRecordStaffWrite(companyId) && meetingRecordUpdateValid(companyId);
        allow delete: if meetingRecordStaffWrite(companyId);

        match /internal/{docId} {
          allow read: if meetingRecordStaffRead(companyId);
          allow create, update: if meetingRecordStaffWrite(companyId) && docId == 'data';
          allow delete: if meetingRecordStaffWrite(companyId) && docId == 'data';
        }
      }

      match /jobs/{jobId} {
        allow read: if terminalCompanyMatches(companyId) ||
          customerPortalLinkedJob(companyId, jobId) ||
          (signedIn() && sameCompany(companyId) &&
            jobDetailReadAccess(companyId, jobId) &&
            !jobEmployeeMustUseSummaryOnly(companyId, jobId));
        allow create, update, delete: if signedIn() && sameCompany(companyId) && isPrivileged();

        /**
         * Spotřeba materiálu na zakázce — zápis přes API (Admin SDK); čtení výroba / vedení.
         * companies/{companyId}/jobs/{jobId}/materialConsumptions/{consumptionId}
         */
        match /materialConsumptions/{consumptionId} {
          allow read: if signedIn() && sameCompany(companyId) && (
            isPrivileged() ||
            (userRole() == 'employee' && jobAssignedForProduction(companyId, jobId) && employeeProductionFlag(companyId))
          );
          allow write: if false;
        }

        /**
         * Návrh materiálu z CSV (draft) — zápis přes API; čtení výroba / vedení.
         * companies/{companyId}/jobs/{jobId}/csvMaterialDrafts/{draftId}
         */
        match /csvMaterialDrafts/{draftId} {
          allow read: if signedIn() && sameCompany(companyId) && (
            isPrivileged() ||
            (userRole() == 'employee' && jobAssignedForProduction(companyId, jobId) && employeeProductionFlag(companyId))
          );
          allow write: if false;
        }

        /** Bezpečný náhled zakázky pro zaměstnance (bez rozpočtu). */
        match /employeeSummary/summary {
          allow read: if signedIn() && sameCompany(companyId) && (
            isPrivileged() || jobPortalEmployeeEligible(companyId, jobId)
          );
          allow write: if signedIn() && sameCompany(companyId) && isPrivileged();
        }

        /** Přiřazení a režim přístupu k zakázce (klíč = employees/{id}). */
        match /jobMembers/{memberEmpId} {
          allow read: if signedIn() && sameCompany(companyId) && (
            isPrivileged() ||
            (ownEmployeeId() != null && memberEmpId == ownEmployeeId())
          );
          allow create, update, delete: if signedIn() && sameCompany(companyId) && isPrivileged();
        }

        match /photos/{photoId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId) ||
            (jobEmployeeLimitedMediaProfile(companyId, jobId) &&
              legacyJobPhotosEmployeeAllowed(companyId, jobId) &&
              (!('employeeVisible' in resource.data) ||
                resource.data.employeeVisible == true)) ||
            (customerPortalLinkedJob(companyId, jobId) && jobLegacyPhotoCustomerPortalReadOk());
          allow create: if jobFinancialReadAccess(companyId, jobId) &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.createdBy == request.auth.uid;
          allow update: if jobFinancialReadAccess(companyId, jobId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId &&
            (isPrivileged() || resource.data.createdBy == request.auth.uid) ||
            (customerPortalLinkedJob(companyId, jobId) &&
              jobLegacyPhotoCustomerPortalReadOk() &&
              jobLegacyPhotoCustomerApprovalUpdateOk());
          allow delete: if userRole() != 'customer' &&
            jobFinancialReadAccess(companyId, jobId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId &&
            (isPrivileged() || resource.data.createdBy == request.auth.uid);
        }

        /**
         * Sdílené anotace nad médiem (kresba, čáry, text) — nezávislé na annotationData souboru.
         * companies/{companyId}/jobs/{jobId}/document_annotations/{docId}
         */
        match /document_annotations/{annId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId) ||
            jobEmployeeLimitedMediaProfile(companyId, jobId) ||
            (signedIn() && sameCompany(companyId) &&
              jobDetailReadAccess(companyId, jobId) &&
              !jobEmployeeMustUseSummaryOnly(companyId, jobId)) ||
            customerPortalLinkedJob(companyId, jobId);
          allow create: if signedIn() && sameCompany(companyId) &&
            jobDocumentAnnotationPayloadOk() &&
            jobDocumentAnnotationReviewFieldsOk() &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId && (
              (isPrivileged() &&
                jobDetailReadAccess(companyId, jobId) &&
                !jobEmployeeMustUseSummaryOnly(companyId, jobId)) ||
              customerPortalLinkedJob(companyId, jobId)
            );
          allow update: if signedIn() && sameCompany(companyId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId &&
            jobDocumentAnnotationPayloadOk() &&
            jobDocumentAnnotationReviewFieldsOk() && (
              (isPrivileged() &&
                jobDetailReadAccess(companyId, jobId) &&
                !jobEmployeeMustUseSummaryOnly(companyId, jobId)) ||
              customerPortalLinkedJob(companyId, jobId)
            );
          allow delete: if false;
        }

        /**
         * Výběry produktů zákazníka v katalogu.
         * companies/{companyId}/jobs/{jobId}/product_catalog_selections/{selectionId}
         */
        match /product_catalog_selections/{selectionId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId) ||
            customerPortalLinkedJob(companyId, jobId);
          allow create: if signedIn() && sameCompany(companyId) && (
            (isPrivileged() && jobDetailReadAccess(companyId, jobId)) ||
            (
              customerPortalLinkedJob(companyId, jobId) &&
              request.resource.data.jobId == jobId &&
              request.resource.data.companyId == companyId &&
              request.resource.data.selectedBy == request.auth.uid &&
              request.resource.data.customerPortalUid == request.auth.uid &&
              request.resource.data.status in ['draft', 'submitted']
            )
          );
          allow update: if signedIn() && sameCompany(companyId) && (
            (isPrivileged() && jobDetailReadAccess(companyId, jobId)) ||
            (
              customerPortalLinkedJob(companyId, jobId) &&
              resource.data.customerPortalUid == request.auth.uid &&
              resource.data.status != 'confirmed' &&
              request.resource.data.jobId == jobId &&
              request.resource.data.companyId == companyId &&
              request.resource.data.selectedBy == request.auth.uid &&
              request.resource.data.customerPortalUid == request.auth.uid &&
              request.resource.data.status in ['draft', 'submitted']
            )
          );
          allow delete: if signedIn() && sameCompany(companyId) && (
            (isPrivileged() && jobDetailReadAccess(companyId, jobId)) ||
            (
              customerPortalLinkedJob(companyId, jobId) &&
              resource.data.customerPortalUid == request.auth.uid
            )
          );
        }

        /**
         * Příjmy (úhrady) zaúčtované ze složky dokladů — id dokumentu = id souboru ve složce.
         * companies/{companyId}/jobs/{jobId}/incomes/{incomeId}
         */
        match /incomes/{incomeId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId);
          allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.type == 'income' &&
            request.resource.data.date is string &&
            request.resource.data.date.size() > 0 &&
            request.resource.data.date.size() <= 32 &&
            request.resource.data.amountNet is number &&
            request.resource.data.amountGross is number &&
            request.resource.data.amountNet >= 0 &&
            request.resource.data.amountGross >= request.resource.data.amountNet;
          allow update: if false;
          allow delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId;
        }

        /** Náklady zakázky (částka, datum, poznámka, příloha). Zapisují vedení / účetnictví. */
        match /expenses/{expenseId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId);
          allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.amount is number &&
            request.resource.data.amount > 0 &&
            request.resource.data.date is string &&
            request.resource.data.date.size() > 0 &&
            request.resource.data.date.size() <= 32 &&
            (!('note' in request.resource.data) ||
              request.resource.data.note == null ||
              (request.resource.data.note is string &&
                request.resource.data.note.size() <= 4000)) &&
            (!('fileUrl' in request.resource.data) ||
              request.resource.data.fileUrl == null ||
              (request.resource.data.fileUrl is string &&
                request.resource.data.fileUrl.size() > 0 &&
                request.resource.data.fileUrl.size() <= 2048)) &&
            (!('fileType' in request.resource.data) ||
              request.resource.data.fileType == null ||
              request.resource.data.fileType in ['image', 'pdf', 'office']) &&
            (!('fileName' in request.resource.data) ||
              request.resource.data.fileName == null ||
              (request.resource.data.fileName is string &&
                request.resource.data.fileName.size() <= 500)) &&
            (!('storagePath' in request.resource.data) ||
              request.resource.data.storagePath == null ||
              (request.resource.data.storagePath is string &&
                request.resource.data.storagePath.size() <= 1024)) &&
            (!('vatRate' in request.resource.data) ||
              (request.resource.data.vatRate is number &&
                request.resource.data.vatRate >= 0 &&
                request.resource.data.vatRate <= 100)) &&
            (!('vatAmount' in request.resource.data) ||
              (request.resource.data.vatAmount is number &&
                request.resource.data.vatAmount >= 0)) &&
            (!('amountGross' in request.resource.data) ||
              (request.resource.data.amountGross is number &&
                request.resource.data.amountGross >= request.resource.data.amount)) &&
            (!('amountNet' in request.resource.data) ||
              (request.resource.data.amountNet is number &&
                request.resource.data.amountNet == request.resource.data.amount)) &&
            (!('dokladId' in request.resource.data) ||
              (request.resource.data.dokladId is string &&
                request.resource.data.dokladId.size() >= 1 &&
                request.resource.data.dokladId.size() <= 128)) &&
            (!('source' in request.resource.data) ||
              (request.resource.data.source is string &&
                request.resource.data.source.size() >= 1 &&
                request.resource.data.source.size() <= 64));
          allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId &&
            resource.data.createdBy == request.resource.data.createdBy &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.createdBy == resource.data.createdBy &&
            request.resource.data.amount is number &&
            request.resource.data.amount > 0 &&
            request.resource.data.date is string &&
            request.resource.data.date.size() > 0 &&
            request.resource.data.date.size() <= 32 &&
            (!('note' in request.resource.data) ||
              request.resource.data.note == null ||
              (request.resource.data.note is string &&
                request.resource.data.note.size() <= 4000)) &&
            (!('fileUrl' in request.resource.data) ||
              request.resource.data.fileUrl == null ||
              (request.resource.data.fileUrl is string &&
                request.resource.data.fileUrl.size() > 0 &&
                request.resource.data.fileUrl.size() <= 2048)) &&
            (!('fileType' in request.resource.data) ||
              request.resource.data.fileType == null ||
              request.resource.data.fileType in ['image', 'pdf', 'office']) &&
            (!('fileName' in request.resource.data) ||
              request.resource.data.fileName == null ||
              (request.resource.data.fileName is string &&
                request.resource.data.fileName.size() <= 500)) &&
            (!('storagePath' in request.resource.data) ||
              request.resource.data.storagePath == null ||
              (request.resource.data.storagePath is string &&
                request.resource.data.storagePath.size() <= 1024)) &&
            (!('vatRate' in request.resource.data) ||
              (request.resource.data.vatRate is number &&
                request.resource.data.vatRate >= 0 &&
                request.resource.data.vatRate <= 100)) &&
            (!('vatAmount' in request.resource.data) ||
              (request.resource.data.vatAmount is number &&
                request.resource.data.vatAmount >= 0)) &&
            (!('amountGross' in request.resource.data) ||
              (request.resource.data.amountGross is number &&
                request.resource.data.amountGross >= request.resource.data.amount)) &&
            (!('amountNet' in request.resource.data) ||
              (request.resource.data.amountNet is number &&
                request.resource.data.amountNet == request.resource.data.amount)) &&
            (!('dokladId' in request.resource.data) ||
              (request.resource.data.dokladId is string &&
                request.resource.data.dokladId.size() >= 1 &&
                request.resource.data.dokladId.size() <= 128)) &&
            (!('source' in request.resource.data) ||
              (request.resource.data.source is string &&
                request.resource.data.source.size() >= 1 &&
                request.resource.data.source.size() <= 64));
          allow delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId;
        }

        /**
         * Smlouvy o dílo u zakázky — companies/{companyId}/jobs/{jobId}/workContracts/{contractId}
         */
        match /workContracts/{contractId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId);
          allow create, update, delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId);
        }

        /**
         * Zrcadlení fakturačních dokladů (záloha / daňový doklad) — jen odkaz na companies/.../invoices.
         * companies/{companyId}/jobs/{jobId}/billingDocuments/{docId}
         */
        match /billingDocuments/{docId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId);
          allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.invoiceId is string &&
            request.resource.data.kind in ['advance_invoice', 'tax_receipt_received_payment', 'final_invoice'];
          allow update, delete: if false;
        }

        /**
         * Historie odeslání dokumentů e-mailem ze zakázky (zápis přes Admin API).
         * companies/{companyId}/jobs/{jobId}/documentEmailLogs/{logId}
         */
        match /documentEmailLogs/{logId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId);
          allow create, update, delete: if false;
        }

        /**
         * Úkoly zakázky: companies/{companyId}/jobs/{jobId}/tasks/{taskId}
         * taskScope == 'job' odliší záznam od companies/{companyId}/tasks (task manager).
         */
        match /tasks/{taskId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId);
          allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.taskScope == 'job' &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.title is string &&
            request.resource.data.title.size() > 0 &&
            request.resource.data.title.size() <= 500 &&
            request.resource.data.status == 'active' &&
            request.resource.data.priority in ['low', 'medium', 'high'] &&
            request.resource.data.dueDate is string &&
            request.resource.data.dueDate.size() > 0 &&
            request.resource.data.dueDate.size() <= 32 &&
            (!('note' in request.resource.data) ||
              request.resource.data.note == null ||
              (request.resource.data.note is string &&
                request.resource.data.note.size() <= 8000));
          allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId &&
            resource.data.taskScope == 'job' &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.taskScope == 'job' &&
            resource.data.createdBy == request.resource.data.createdBy &&
            request.resource.data.title is string &&
            request.resource.data.title.size() > 0 &&
            request.resource.data.title.size() <= 500 &&
            request.resource.data.status in ['active', 'done'] &&
            request.resource.data.priority in ['low', 'medium', 'high'] &&
            request.resource.data.dueDate is string &&
            request.resource.data.dueDate.size() > 0 &&
            request.resource.data.dueDate.size() <= 32 &&
            (!('note' in request.resource.data) ||
              request.resource.data.note == null ||
              (request.resource.data.note is string &&
                request.resource.data.note.size() <= 8000));
          allow delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId &&
            resource.data.taskScope == 'job';
        }

        /**
         * Úkoly pro zákazníka (klientský portál): companies/{companyId}/jobs/{jobId}/customer_tasks/{taskId}
         */
        match /customer_tasks/{taskId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId) ||
            (customerPortalLinkedJob(companyId, jobId) &&
              resource.data.assignedCustomerUid == request.auth.uid);
          allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.assignedCustomerUid is string &&
            request.resource.data.assignedCustomerUid.size() > 0 &&
            request.resource.data.title is string &&
            request.resource.data.title.size() > 0 &&
            request.resource.data.title.size() <= 500 &&
            request.resource.data.description is string &&
            request.resource.data.description.size() <= 8000 &&
            request.resource.data.type in [
              'select_products', 'fill_questionnaire', 'provide_details',
              'confirm_info', 'upload_documents', 'custom'
            ] &&
            request.resource.data.status in ['pending', 'completed', 'cancelled'] &&
            request.resource.data.autoGenerated is bool &&
            request.resource.data.createdBy == request.auth.uid &&
            (!('dueDate' in request.resource.data) ||
              request.resource.data.dueDate == null ||
              (request.resource.data.dueDate is string &&
                request.resource.data.dueDate.size() > 0 &&
                request.resource.data.dueDate.size() <= 32)) &&
            (!('customerId' in request.resource.data) ||
              request.resource.data.customerId == null ||
              (request.resource.data.customerId is string &&
                request.resource.data.customerId.size() > 0));
          allow update: if
            (signedIn() && sameCompany(companyId) && isPrivileged() &&
              jobDetailReadAccess(companyId, jobId) &&
              resource.data.companyId == companyId &&
              resource.data.jobId == jobId &&
              request.resource.data.companyId == companyId &&
              request.resource.data.jobId == jobId &&
              request.resource.data.assignedCustomerUid == resource.data.assignedCustomerUid &&
              request.resource.data.title is string &&
              request.resource.data.title.size() > 0 &&
              request.resource.data.title.size() <= 500 &&
              request.resource.data.description is string &&
              request.resource.data.description.size() <= 8000 &&
              request.resource.data.type in [
                'select_products', 'fill_questionnaire', 'provide_details',
                'confirm_info', 'upload_documents', 'custom'
              ] &&
              request.resource.data.status in ['pending', 'completed', 'cancelled'] &&
              request.resource.data.autoGenerated == resource.data.autoGenerated &&
              request.resource.data.createdBy == resource.data.createdBy &&
              (!('dueDate' in request.resource.data) ||
                request.resource.data.dueDate == null ||
                (request.resource.data.dueDate is string &&
                  request.resource.data.dueDate.size() > 0 &&
                  request.resource.data.dueDate.size() <= 32))) ||
            (customerPortalLinkedJob(companyId, jobId) &&
              resource.data.assignedCustomerUid == request.auth.uid &&
              resource.data.status == 'pending' &&
              request.resource.data.status == 'completed' &&
              request.resource.data.companyId == resource.data.companyId &&
              request.resource.data.jobId == resource.data.jobId &&
              request.resource.data.assignedCustomerUid == resource.data.assignedCustomerUid &&
              request.resource.data.title == resource.data.title &&
              request.resource.data.description == resource.data.description &&
              request.resource.data.type == resource.data.type &&
              request.resource.data.autoGenerated == resource.data.autoGenerated &&
              request.resource.data.createdBy == resource.data.createdBy &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completedAt', 'updatedAt']));
          allow delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId) &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId;
        }

        /**
         * Odpovědi zákazníka na dotazník: dokument id = customerPortalUid
         */
        match /customer_questionnaire_responses/{responseId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId) ||
            (customerPortalLinkedJob(companyId, jobId) &&
              resource.data.customerPortalUid == request.auth.uid);
          allow create: if customerPortalLinkedJob(companyId, jobId) &&
            request.auth.uid == responseId &&
            request.resource.data.customerPortalUid == request.auth.uid &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.status == 'draft' &&
            request.resource.data.questions is list &&
            request.resource.data.answers is map;
          allow update: if customerPortalLinkedJob(companyId, jobId) &&
            resource.data.customerPortalUid == request.auth.uid &&
            request.auth.uid == responseId &&
            request.resource.data.customerPortalUid == resource.data.customerPortalUid &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.questions is list &&
            request.resource.data.answers is map &&
            resource.data.status == 'draft' &&
            request.resource.data.status in ['draft', 'submitted'];
          allow delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            jobDetailReadAccess(companyId, jobId);
        }

        match /folders/{folderId} {
          allow read: if terminalCompanyMatches(companyId) ||
            jobFinancialReadAccess(companyId, jobId) ||
            (jobEmployeeLimitedMediaProfile(companyId, jobId) &&
              folderDocEmployeeVisible(companyId, jobId, folderId)) ||
            (jobProductionMediaReader(companyId, jobId) &&
              folderDocProductionTeamVisible(companyId, jobId, folderId)) ||
            (customerPortalLinkedJob(companyId, jobId) &&
              resource.data.internalOnly != true &&
              resource.data.customerVisible == true &&
              resource.data.type != 'documents');
          allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            request.resource.data.companyId == companyId &&
            request.resource.data.jobId == jobId &&
            request.resource.data.name is string &&
            request.resource.data.name.size() > 0 &&
            request.resource.data.name.size() <= 120 &&
            request.resource.data.createdBy == request.auth.uid &&
            (!('type' in request.resource.data) ||
              request.resource.data.type in ['photos', 'documents', 'files']);
          allow update, delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
            resource.data.companyId == companyId &&
            resource.data.jobId == jobId &&
            (!('type' in request.resource.data) ||
              request.resource.data.type in ['photos', 'documents', 'files']);

          match /images/{imageId} {
            allow read: if terminalCompanyMatches(companyId) ||
              jobFinancialReadAccess(companyId, jobId) ||
              (jobEmployeeLimitedMediaProfile(companyId, jobId) &&
                folderDocEmployeeVisible(companyId, jobId, folderId) &&
                (!('employeeVisible' in resource.data) ||
                  resource.data.employeeVisible == true)) ||
              (jobProductionMediaReader(companyId, jobId) &&
                folderDocProductionTeamVisible(companyId, jobId, folderId) &&
                (!(resource.data.internalOnly is bool) || resource.data.internalOnly != true)) ||
              jobMediaCustomerPortalImageReadOk(companyId, jobId, folderId);
            allow create: if (jobFinancialReadAccess(companyId, jobId) &&
                request.resource.data.companyId == companyId &&
                request.resource.data.jobId == jobId &&
                request.resource.data.folderId == folderId &&
                request.resource.data.createdBy == request.auth.uid &&
                request.resource.data.storagePath is string) ||
              (jobEmployeeLimitedMediaProfile(companyId, jobId) &&
                folderDocEmployeeVisible(companyId, jobId, folderId) &&
                folderDocEmployeeUploadAllowed(companyId, jobId, folderId) &&
                request.resource.data.companyId == companyId &&
                request.resource.data.jobId == jobId &&
                request.resource.data.folderId == folderId &&
                request.resource.data.createdBy == request.auth.uid &&
                request.resource.data.storagePath is string &&
                request.resource.data.uploadSource == 'employee-job-upload' &&
                request.resource.data.uploadedByEmployeeId == ownEmployeeId());
            allow update: if (jobFinancialReadAccess(companyId, jobId) &&
                resource.data.companyId == companyId &&
                resource.data.jobId == jobId &&
                resource.data.folderId == folderId &&
                (isPrivileged() || resource.data.createdBy == request.auth.uid)) ||
              (jobEmployeeLimitedMediaProfile(companyId, jobId) &&
                folderDocEmployeeVisible(companyId, jobId, folderId) &&
                resource.data.companyId == companyId &&
                resource.data.jobId == jobId &&
                resource.data.folderId == folderId &&
                resource.data.createdBy == request.auth.uid &&
                request.resource.data.companyId == companyId &&
                request.resource.data.jobId == jobId &&
                request.resource.data.folderId == folderId &&
                request.resource.data.createdBy == resource.data.createdBy) ||
              (customerPortalLinkedJob(companyId, jobId) &&
                jobMediaCustomerPortalImageReadOk(companyId, jobId, folderId) &&
                jobFolderImageCustomerApprovalUpdateOk());
            allow delete: if userRole() != 'customer' &&
              ((jobFinancialReadAccess(companyId, jobId) &&
                resource.data.companyId == companyId &&
                resource.data.jobId == jobId &&
                resource.data.folderId == folderId &&
                (isPrivileged() || resource.data.createdBy == request.auth.uid)) ||
              (jobEmployeeLimitedMediaProfile(companyId, jobId) &&
                folderDocEmployeeVisible(companyId, jobId, folderId) &&
                resource.data.companyId == companyId &&
                resource.data.jobId == jobId &&
                resource.data.folderId == folderId &&
                resource.data.createdBy == request.auth.uid));
          }
        }
      }

      /**
       * Úkoly organizace (task manager): companies/{companyId}/tasks/{taskId}
       */
      match /tasks/{taskId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() ||
            resource.data.assignedTo == null ||
            resource.data.assignedTo == ownEmployeeId());
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.organizationId == companyId &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.title.size() <= 500 &&
          request.resource.data.status == 'open' &&
          (!('description' in request.resource.data) ||
            request.resource.data.description == null ||
            (request.resource.data.description is string &&
              request.resource.data.description.size() <= 8000)) &&
          (!('assignedTo' in request.resource.data) ||
            request.resource.data.assignedTo == null ||
            (request.resource.data.assignedTo is string &&
              request.resource.data.assignedTo.size() > 0));
        allow update: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          (ownEmployeeId() != null &&
            (resource.data.assignedTo == ownEmployeeId() ||
              resource.data.assignedTo == null))
        );
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /** Plánovaná zaměření před zakázkou: companies/{companyId}/measurements/{measurementId} */
      match /measurements/{measurementId} {
        allow read, write: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /**
       * Foto zaměření s anotacemi — companies/{companyId}/measurement_photos/{photoId}
       */
      match /measurement_photos/{photoId} {
        allow read: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          resource.data.createdBy == request.auth.uid ||
          (resource.data.customerId is string && resource.data.customerId.size() > 0 &&
            (!(resource.data.jobId is string) || resource.data.jobId.size() == 0)) ||
          (resource.data.jobId is string && resource.data.jobId.size() > 0 && (
            jobFinancialReadAccess(companyId, resource.data.jobId) ||
            (jobEmployeeLimitedMediaProfile(companyId, resource.data.jobId) &&
              resource.data.employeeVisible == true)
          ))
        );
        allow create: if signedIn() && sameCompany(companyId) &&
          request.resource.data.companyId == companyId &&
          request.resource.data.sourceType == 'measurement-photo' &&
          request.resource.data.createdBy == request.auth.uid && (
            (request.resource.data.jobId is string && request.resource.data.jobId.size() > 0 &&
              jobFinancialReadAccess(companyId, request.resource.data.jobId)) ||
            (!('jobId' in request.resource.data) || request.resource.data.jobId == null)
          );
        allow update: if signedIn() && sameCompany(companyId) &&
          resource.data.companyId == companyId &&
          request.resource.data.companyId == companyId && (
            isPrivileged() ||
            (resource.data.createdBy == request.auth.uid &&
              (!(resource.data.jobId is string) || resource.data.jobId.size() == 0 ||
                jobFinancialReadAccess(companyId, resource.data.jobId)) &&
              (!(request.resource.data.jobId is string) || request.resource.data.jobId.size() == 0 ||
                jobFinancialReadAccess(companyId, request.resource.data.jobId)))
          );
        allow delete: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          (resource.data.createdBy == request.auth.uid && (
            (!(resource.data.jobId is string) || resource.data.jobId.size() == 0) ||
            jobFinancialReadAccess(companyId, resource.data.jobId)
          ))
        );
      }

      /**
       * Zálohy / výplaty: companies/{companyId}/advances/{advanceId}
       * Pole: amount (number), date (string), employeeId, companyId, note, status (paid|unpaid),
       * createdAt, updatedAt, createdBy (uid).
       * Zaměstnanec čte jen své záznamy, správa jen isPrivileged().
       */
      match /advances/{advanceId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId());
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId is string &&
          request.resource.data.amount is number &&
          request.resource.data.status in ['paid', 'unpaid'];
        allow update, delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /**
       * Výplaty za měsíc (evidence vyplaceno / stav): payroll_period_payments/{id}
       * ID např. {employeeId}__{YYYY-MM}
       */
      match /payroll_period_payments/{ppId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId());
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId is string &&
          request.resource.data.payrollPeriod is string &&
          request.resource.data.payrollPeriod.matches('^\\d{4}-\\d{2}$') &&
          request.resource.data.calculatedAmount is number &&
          request.resource.data.paidAmount is number &&
          request.resource.data.paymentDate is string &&
          request.resource.data.paymentStatus in ['unpaid', 'partial', 'paid'];
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          resource.data.companyId == companyId &&
          request.resource.data.companyId == companyId &&
          resource.data.employeeId == request.resource.data.employeeId &&
          resource.data.payrollPeriod == request.resource.data.payrollPeriod &&
          request.resource.data.calculatedAmount is number &&
          request.resource.data.paidAmount is number &&
          request.resource.data.paymentDate is string &&
          request.resource.data.paymentStatus in ['unpaid', 'partial', 'paid'];
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /** Dluhy zaměstnanců: admin správa, zaměstnanec pouze čtení svého. */
      match /employee_debts/{debtId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId());
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId is string &&
          request.resource.data.amount is number &&
          request.resource.data.amount > 0 &&
          request.resource.data.remainingAmount is number &&
          request.resource.data.remainingAmount >= 0 &&
          request.resource.data.status in ['active', 'paid', 'overpaid'];
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          resource.data.companyId == companyId &&
          resource.data.employeeId == request.resource.data.employeeId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId == resource.data.employeeId &&
          request.resource.data.amount is number &&
          request.resource.data.amount > 0 &&
          request.resource.data.remainingAmount is number &&
          request.resource.data.status in ['active', 'paid', 'overpaid'];
        /** Doplacený dluh nesmí zmizet — mazání jen u aktivního záznamu. */
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          resource.data.status == 'active';
      }

      /** Splátky dluhů: admin zapisuje/upravuje/mazání, zaměstnanec čte své. */
      match /employee_debt_payments/{paymentId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId());
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId is string &&
          request.resource.data.debtId is string &&
          request.resource.data.amount is number &&
          request.resource.data.amount > 0 &&
          (!('paymentMethod' in request.resource.data) ||
            (request.resource.data.paymentMethod is string &&
              request.resource.data.paymentMethod.size() <= 120)) &&
          (!('paidBy' in request.resource.data) ||
            (request.resource.data.paidBy is string &&
              request.resource.data.paidBy.size() <= 200));
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          resource.data.companyId == companyId &&
          resource.data.employeeId == request.resource.data.employeeId &&
          resource.data.debtId == request.resource.data.debtId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId is string &&
          request.resource.data.debtId is string &&
          request.resource.data.amount is number &&
          request.resource.data.amount > 0 &&
          (!('paymentMethod' in request.resource.data) ||
            (request.resource.data.paymentMethod is string &&
              request.resource.data.paymentMethod.size() <= 120)) &&
          (!('paidBy' in request.resource.data) ||
            (request.resource.data.paidBy is string &&
              request.resource.data.paidBy.size() <= 200));
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /**
       * Auditní historie uzavření dluhu (append-only na klientovi admina).
       * companies/{companyId}/employee_debt_history/{id}
       */
      match /employee_debt_history/{historyId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId());
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId is string &&
          request.resource.data.debtId is string &&
          request.resource.data.originalAmount is number &&
          request.resource.data.originalAmount > 0 &&
          request.resource.data.debtDate is string &&
          request.resource.data.debtDate.size() <= 40 &&
          request.resource.data.paidBy is string &&
          request.resource.data.status in ['paid', 'overpaid'] &&
          (!('paidByName' in request.resource.data) ||
            request.resource.data.paidByName == null ||
            (request.resource.data.paidByName is string &&
              request.resource.data.paidByName.size() <= 200)) &&
          (!('settlementMethod' in request.resource.data) ||
            request.resource.data.settlementMethod == null ||
            (request.resource.data.settlementMethod is string &&
              request.resource.data.settlementMethod.size() <= 120)) &&
          (!('closureNote' in request.resource.data) ||
            (request.resource.data.closureNote is string &&
              request.resource.data.closureNote.size() <= 4000)) &&
          (!('debtNote' in request.resource.data) ||
            (request.resource.data.debtNote is string &&
              request.resource.data.debtNote.size() <= 4000)) &&
          (!('remainingAfterClose' in request.resource.data) ||
            (request.resource.data.remainingAfterClose is number));
        allow update, delete: if false;
      }

      match /attendance/{documentId} {
        allow read: if terminalCompanyMatches(companyId) || (signedIn() && sameCompany(companyId));
        allow create: if (terminalCompanyMatches(companyId) || (signedIn() && sameCompany(companyId))) && attendanceJobValid(companyId);
        allow update, delete: if terminalCompanyMatches(companyId) || (signedIn() && sameCompany(companyId));
      }

      /** Nastavení terminálu (token pro /terminal-access/…) — jen privilegované role. */
      match /settings/{docId} {
        allow read, write: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /** Chat zaměstnanec ↔ administrace: companies/{companyId}/chat/{messageId} */
      match /chat/{messageId} {
        allow read: if signedIn() && sameCompany(companyId);
        allow create: if signedIn() && sameCompany(companyId) &&
          request.resource.data.companyId == companyId &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 8000 &&
          request.resource.data.read == false &&
          request.resource.data.senderRole in ['employee', 'admin'] &&
          request.resource.data.senderName is string &&
          request.resource.data.senderName.size() > 0 &&
          request.resource.data.senderName.size() <= 200 &&
          request.resource.data.senderPhotoURL is string &&
          request.resource.data.senderPhotoURL.size() <= 2000 &&
          (!('employeeId' in request.resource.data) ||
            (request.resource.data.employeeId is string &&
             request.resource.data.employeeId.size() <= 200)) &&
          (
            (request.resource.data.senderRole == 'employee' && canLogOwnWorkTime()) ||
            (request.resource.data.senderRole == 'admin' && isPrivileged())
          );
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.senderId == resource.data.senderId &&
          request.resource.data.companyId == resource.data.companyId &&
          request.resource.data.text == resource.data.text &&
          request.resource.data.senderRole == resource.data.senderRole &&
          request.resource.data.read is bool &&
          resource.data.read == false &&
          request.resource.data.read == true;
        allow delete: if false;
      }

      /** Interní tarify práce (cesta, administrativa, …) — správa privilegovaně; čtení i zaměstnanec (výběr v docházce). */
      match /work_tariffs/{tariffId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || canLogOwnWorkTime());
        allow create, update, delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /**
       * Úseky práce na zakázkách / tarifech — zápis přes Admin API.
       * Čtení: vlastní + privilegovaní, nebo anonymně jen otevřené úseky (terminál /attendance-login — companyId v cestě).
       */
      match /work_segments/{segmentId} {
        allow read: if (signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId())) ||
          (request.auth == null &&
            resource.data.companyId == companyId &&
            resource.data.closed == false);
        allow write: if false;
      }

      /**
       * Štítky / stavy poptávek (import) — companies/{companyId}/lead_tags/{tagId}
       */
      match /lead_tags/{tagId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          userRole() in ['owner', 'admin', 'manager', 'accountant', 'employee'];
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.name is string &&
          request.resource.data.name.size() > 0 &&
          request.resource.data.name.size() <= 120 &&
          request.resource.data.sortOrder is number &&
          (!('color' in request.resource.data) ||
            (request.resource.data.color is string &&
              request.resource.data.color.matches('^#[0-9A-Fa-f]{6}$')));
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          resource.data.companyId == companyId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.name is string &&
          request.resource.data.name.size() > 0 &&
          request.resource.data.name.size() <= 120 &&
          request.resource.data.sortOrder is number &&
          (!('color' in request.resource.data) ||
            (request.resource.data.color is string &&
              request.resource.data.color.matches('^#[0-9A-Fa-f]{6}$')));
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /**
       * Naplánované schůzky k poptávkám — companies/{companyId}/lead_meetings/{meetingId}
       */
      match /lead_meetings/{meetingId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          userRole() in ['owner', 'admin', 'manager', 'accountant', 'employee'];
        allow create: if signedIn() && sameCompany(companyId) &&
          userRole() in ['owner', 'admin', 'manager', 'accountant', 'employee'] &&
          request.resource.data.companyId == companyId &&
          request.resource.data.importLeadId is string &&
          request.resource.data.importLeadId.size() > 0 &&
          request.resource.data.leadKey is string &&
          request.resource.data.leadKey.size() > 0 &&
          request.resource.data.customerName is string &&
          request.resource.data.customerName.size() > 0 &&
          request.resource.data.customerName.size() <= 300 &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.scheduledAt is timestamp &&
          (!('phone' in request.resource.data) || request.resource.data.phone is string) &&
          (!('email' in request.resource.data) || request.resource.data.email is string) &&
          (!('note' in request.resource.data) ||
            (request.resource.data.note is string && request.resource.data.note.size() <= 8000)) &&
          (!('place' in request.resource.data) ||
            (request.resource.data.place is string && request.resource.data.place.size() <= 500));
        allow update: if signedIn() && sameCompany(companyId) &&
          userRole() in ['owner', 'admin', 'manager', 'accountant', 'employee'] &&
          resource.data.companyId == companyId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.importLeadId == resource.data.importLeadId &&
          request.resource.data.leadKey == resource.data.leadKey &&
          request.resource.data.createdBy == resource.data.createdBy &&
          (!('phone' in request.resource.data) || request.resource.data.phone is string) &&
          (!('email' in request.resource.data) || request.resource.data.email is string) &&
          (!('note' in request.resource.data) ||
            (request.resource.data.note is string && request.resource.data.note.size() <= 8000)) &&
          (!('place' in request.resource.data) ||
            (request.resource.data.place is string && request.resource.data.place.size() <= 500)) &&
          request.resource.data.scheduledAt is timestamp;
        allow delete: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.createdBy == request.auth.uid);
      }

      /**
       * Přiřazení štítku k importované poptávce (klíč = stabilní id z importu).
       * companies/{companyId}/import_lead_overlays/{leadKey}
       */
      match /import_lead_overlays/{leadKey} {
        allow read: if signedIn() && sameCompany(companyId) &&
          userRole() in ['owner', 'admin', 'manager', 'accountant', 'employee'];
        allow create: if signedIn() && sameCompany(companyId) &&
          userRole() in ['owner', 'admin', 'manager', 'accountant', 'employee'] &&
          request.resource.data.companyId == companyId &&
          request.resource.data.importLeadId is string &&
          request.resource.data.importLeadId.size() > 0 &&
          request.resource.data.updatedByUid == request.auth.uid &&
          (!('tagId' in request.resource.data) ||
            request.resource.data.tagId == null ||
            (request.resource.data.tagId is string && request.resource.data.tagId.size() > 0)) &&
          (!('internalNote' in request.resource.data) ||
            (request.resource.data.internalNote is string &&
              request.resource.data.internalNote.size() <= 12000)) &&
          (!('receivedAt' in request.resource.data) || request.resource.data.receivedAt is timestamp);
        allow update: if signedIn() && sameCompany(companyId) &&
          userRole() in ['owner', 'admin', 'manager', 'accountant', 'employee'] &&
          resource.data.companyId == companyId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.importLeadId == resource.data.importLeadId &&
          request.resource.data.updatedByUid == request.auth.uid &&
          (!('tagId' in request.resource.data) ||
            request.resource.data.tagId == null ||
            (request.resource.data.tagId is string && request.resource.data.tagId.size() > 0)) &&
          (!('internalNote' in request.resource.data) ||
            (request.resource.data.internalNote is string &&
              request.resource.data.internalNote.size() <= 12000)) &&
          (!('receivedAt' in request.resource.data) || request.resource.data.receivedAt is timestamp) &&
          (!('receivedAt' in resource.data) ||
            request.resource.data.receivedAt == resource.data.receivedAt);
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /**
       * Audit aktivit — append-only; čtení jen pro vedení nebo super_admin.
       * companies/{companyId}/activityLogs/{logId}
       */
      match /activityLogs/{logId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || isSuperAdminFirebase());
        allow create: if signedIn() && sameCompany(companyId) &&
          request.resource.data.organizationId == companyId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.actionType is string &&
          request.resource.data.actionType.size() > 0 &&
          request.resource.data.actionType.size() <= 120 &&
          request.resource.data.actionLabel is string &&
          request.resource.data.actionLabel.size() > 0 &&
          request.resource.data.actionLabel.size() <= 500 &&
          request.resource.data.entityType is string &&
          request.resource.data.entityType.size() > 0 &&
          request.resource.data.entityType.size() <= 80;
        allow update, delete: if false;
      }

      /**
       * Relace přihlášení (web) — uživatel vytváří / aktualizuje jen vlastní záznam.
       * companies/{companyId}/staffSessions/{sessionId}
       */
      match /staffSessions/{sessionId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || isSuperAdminFirebase());
        allow create: if signedIn() && sameCompany(companyId) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.organizationId == companyId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.sessionId == sessionId &&
          request.resource.data.isActive == true &&
          request.resource.data.loginAt is timestamp;
        allow update: if signedIn() && sameCompany(companyId) &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.organizationId == companyId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.sessionId == sessionId;
        allow delete: if false;
      }

      /**
       * Adresář e-mailů pro odesílání dokladů — companies/{companyId}/documentEmailContacts/{contactId}
       */
      match /documentEmailContacts/{contactId} {
        allow read: if signedIn() && sameCompany(companyId) && isPrivileged();
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.email is string &&
          request.resource.data.email.size() > 3 &&
          request.resource.data.email.size() <= 254 &&
          request.resource.data.label is string &&
          request.resource.data.label.size() > 0 &&
          request.resource.data.label.size() <= 200 &&
          (!('contactType' in request.resource.data) ||
            request.resource.data.contactType in ['accounting', 'customer', 'supplier', 'internal', 'other']);
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          resource.data.companyId == companyId &&
          request.resource.data.companyId == companyId &&
          request.resource.data.email is string &&
          request.resource.data.email.size() > 3 &&
          request.resource.data.email.size() <= 254 &&
          request.resource.data.label is string &&
          request.resource.data.label.size() > 0 &&
          request.resource.data.label.size() <= 200 &&
          (!('contactType' in request.resource.data) ||
            request.resource.data.contactType in ['accounting', 'customer', 'supplier', 'internal', 'other']) &&
          (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          resource.data.companyId == companyId;
      }

      /**
       * Historie odeslání e-mailu u dokladu (zápis Admin SDK po úspěchu).
       * companies/{companyId}/documents/{docId}/emailOutboundHistory/{entryId}
       */
      match /documents/{docId}/emailOutboundHistory/{entryId} {
        allow read: if signedIn() && sameCompany(companyId) && isPrivileged();
        allow create, update, delete: if false;
      }

      /**
       * Historie odeslání e-mailu u faktury (zápis Admin SDK po úspěchu).
       * companies/{companyId}/invoices/{invoiceId}/emailOutboundHistory/{entryId}
       */
      match /invoices/{invoiceId}/emailOutboundHistory/{entryId} {
        allow read: if signedIn() && sameCompany(companyId) && isPrivileged();
        allow create, update, delete: if false;
      }

      /**
       * Firemní doklady (sekce Doklady): přijaté/vydané + zrcadlení nákladů zakázky (source job-expense).
       * companies/{companyId}/documents/{docId}
       */
      match /documents/{docId} {
        allow read: if signedIn() && sameCompany(companyId) && isPrivileged();
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          (companyDocumentIsSyncedMirror(request.resource.data) ||
            companyDocumentIsDeliveryNote(request.resource.data) ||
            companyDocumentHasFinancialAmount(request.resource.data));
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          (companyDocumentIsSyncedMirror(request.resource.data) ||
            companyDocumentIsDeliveryNote(request.resource.data) ||
            companyDocumentHasFinancialAmount(request.resource.data));
        allow delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      // Vše ostatní pod firmou (zakázky, podkolekce, …) — pouze privilegované role.
      // Zaměstnanec se sem nedostane (frontend redirect + tyto pravidla).
      // Výjimka: employees/{id}/private/** je výše explicitně zakázáno; rekurzivní pravidlo by jinak PIN povolilo (OR pravidel).
      match /{document=**} {
        allow read, write: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          !request.path.matches('.*/employees/[^/]+/private/.*');
      }
    }

    match /contractTemplates/{tid} {
      allow read: if signedIn() &&
        resource.data.companyId == userCompanyId();
      allow create: if signedIn() &&
        request.resource.data.companyId == userCompanyId() &&
        isPrivileged();
      allow update, delete: if signedIn() &&
        resource.data.companyId == userCompanyId() &&
        isPrivileged();
    }

    match /platform_invoices/{id} {
      allow read, write: if isSuperAdminFirebase();
    }

    /**
     * Licence firmy — zápis jen při registraci (pending); úpravy přes Admin SDK (superadmin).
     * Dokument company_licenses/{companyId} musí mít companyId shodný s ID dokumentu.
     */
    match /company_licenses/{companyId} {
      allow read: if signedIn() && sameCompany(companyId);
      allow create: if signedIn() &&
        request.resource.data.companyId == companyId &&
        request.resource.data.active == false &&
        request.resource.data.status == 'pending' &&
        !exists(/databases/$(database)/documents/company_licenses/$(companyId));
      allow update, delete: if false;
    }

    /** Globální nastavení platformy — pouze Admin SDK. */
    match /platform_settings/{docId} {
      allow read, write: if false;
    }

    /** Faktury provozovatele platformy — pouze Admin SDK / API. */
    match /platform_invoices/{invoiceId} {
      allow read, write: if false;
    }

    /** Katalog modulů — čtení pro přihlášené (výchozí pro menu / fallback u firmy); zápis jen Admin SDK. */
    match /platform_modules/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /platform_seo/{docId} {
      allow read, write: if false;
    }

    /**
     * Nápověda portálu — čtení jen aktivních řádků pro vlastní firmu nebo globál.
     * Zápis pouze přes Admin API (superadmin).
     */
    match /helpContent/{docId} {
      allow read: if signedIn() &&
        resource.data.isActive == true &&
        (resource.data.companyId == 'global' ||
          (hasUser() && userDoc().companyId != null && resource.data.companyId == userDoc().companyId));
      allow create, update, delete: if false;
    }

    match /organizations/{orgId} {
      allow read, update: if signedIn();
    }

    match /{collectionName}/{orgId} {
      allow read, update: if signedIn() && collectionName == 'společnosti';
      /** Registrace z /register — stejný dokument jako companies/{companyId}, vlastník = auth uid. */
      allow create: if signedIn() &&
        collectionName == 'společnosti' &&
        isNewCompanyOwnedByRequester();
    }

    match /superadmins/{id} {
      allow read, write: if false;
    }

    /** Fronta odchozích e-mailů a deduplikace — pouze Admin SDK / server. */
    match /mail_dispatch_queue/{id} {
      allow read, write: if false;
    }

    match /mail_notify_dedup/{id} {
      allow read, write: if false;
    }
  }
}
