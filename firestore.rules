rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BIZFORGE MULTI-TENANT SAAS SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role markers from User Profile document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && "super_admin" in getUserData().globalRoles;
    }

    function isBillingAdmin() {
      return isSignedIn() && "billing_admin" in getUserData().globalRoles;
    }

    // Role Lookup for Company-Specific Authorization
    function getCompanyRole(companyId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/company_roles/$(companyId)).data.role;
    }

    function hasAnyCompanyRole(companyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/company_roles/$(companyId));
    }

    function hasCompanyRole(companyId, roles) {
      return isSignedIn() && hasAnyCompanyRole(companyId) && getCompanyRole(companyId) in roles;
    }

    // Relational/Path Consistency Helpers
    function matchesPathCompany(pathCompanyId) {
      return request.resource.data.companyId == pathCompanyId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isUser(userId) || isSuperAdmin();
      allow create: if isUser(userId) && request.resource.data.id == userId;
      allow update: if isUser(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isSuperAdmin();
    }

    match /users/{userId}/company_roles/{companyId} {
      allow get, list: if isUser(userId) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner']);
    }

    match /licenses/{licenseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /modules/{moduleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /platform_invoices/{invoiceId} {
      allow get, list: if isSuperAdmin() || isBillingAdmin() || hasCompanyRole(resource.data.companyId, ['owner', 'admin']);
      allow create, update, delete: if isSuperAdmin() || isBillingAdmin();
    }

    match /companies/{companyId} {
      allow get, list: if isSuperAdmin() || hasAnyCompanyRole(companyId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
      allow delete: if isSuperAdmin();
    }

    match /companies/{companyId}/employees/{employeeId} {
      allow get, list: if isSuperAdmin() || hasAnyCompanyRole(companyId);
      allow create: if (isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin'])) && matchesPathCompany(companyId);
      allow update: if (isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin'])) && matchesPathCompany(companyId);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }

    match /companies/{companyId}/customers/{customerId} {
      allow get, list: if isSuperAdmin() || hasAnyCompanyRole(companyId);
      allow create, update: if (isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin', 'manager'])) && matchesPathCompany(companyId);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }

    match /companies/{companyId}/jobs/{jobId} {
      allow get, list: if isSuperAdmin() || hasAnyCompanyRole(companyId);
      allow create, update: if (isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin', 'manager'])) && matchesPathCompany(companyId);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }

    match /companies/{companyId}/attendance/{attendanceId} {
      allow get, list: if isSuperAdmin() || hasAnyCompanyRole(companyId);
      allow create, update: if (isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin', 'manager'])) && matchesPathCompany(companyId);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }

    match /companies/{companyId}/attendance_terminals/{terminalId} {
      allow get, list: if isSuperAdmin() || hasAnyCompanyRole(companyId);
      allow create, update: if (isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin'])) && matchesPathCompany(companyId);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }

    match /companies/{companyId}/documents/{documentId} {
      allow get, list: if isSuperAdmin() || hasAnyCompanyRole(companyId);
      allow create: if (isSuperAdmin() || hasAnyCompanyRole(companyId)) && matchesPathCompany(companyId) && request.resource.data.uploadedByUserId == request.auth.uid;
      allow update: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin', 'manager']);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }

    match /companies/{companyId}/bank_transactions/{bankTransactionId} {
      allow get, list: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin', 'accountant']);
      allow create, update: if (isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin', 'accountant'])) && matchesPathCompany(companyId);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }

    match /companies/{companyId}/chat_conversations/{chatConversationId} {
      allow get, list: if isSuperAdmin() || (hasAnyCompanyRole(companyId) && request.auth.uid in resource.data.participantUserIds);
      allow create: if (isSuperAdmin() || (hasAnyCompanyRole(companyId) && request.auth.uid in request.resource.data.participantUserIds)) && matchesPathCompany(companyId);
      allow update: if isSuperAdmin() || (hasAnyCompanyRole(companyId) && request.auth.uid in resource.data.participantUserIds);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }

    match /companies/{companyId}/chat_conversations/{chatConversationId}/messages/{messageId} {
      allow get, list: if isSuperAdmin() || (isSignedIn() && request.auth.uid in resource.data.participantUserIds);
      allow create: if (isSuperAdmin() || (isSignedIn() && request.auth.uid in request.resource.data.participantUserIds && request.resource.data.senderUserId == request.auth.uid)) && matchesPathCompany(companyId);
      allow update: if isSuperAdmin() || (isSignedIn() && request.auth.uid in resource.data.participantUserIds);
      allow delete: if isSuperAdmin() || hasCompanyRole(companyId, ['owner', 'admin']);
    }
  }
}