rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDoc() {
      return get(userPath()).data;
    }

    function hasUser() {
      return signedIn() && exists(userPath());
    }

    function userCompanyId() {
      return hasUser() ? userDoc().companyId : null;
    }

    function userRole() {
      return hasUser() ? userDoc().role : null;
    }

    function isPrivileged() {
      return userRole() in ['owner', 'admin', 'manager', 'accountant'];
    }

    /** Zaměstnanec může mazat jen vlastní blok ve stavu „čeká“ (nebo legacy bez reviewStatus). */
    function workBlockEmployeeCanSelfDelete() {
      return resource.data.authUserId == request.auth.uid &&
        (!('reviewStatus' in resource.data) ||
          resource.data.reviewStatus == 'pending' ||
          resource.data.reviewStatus == 'rejected');
    }

    function ownEmployeeId() {
      return hasUser() ? userDoc().employeeId : null;
    }

    function isSuperAdminFirebase() {
      return hasUser() &&
        'globalRoles' in userDoc() &&
        userDoc().globalRoles is list &&
        'super_admin' in userDoc().globalRoles;
    }

    function sameCompany(companyId) {
      return hasUser() && userCompanyId() == companyId;
    }

    /**
     * První vytvoření firmy při registraci (batch ještě neobsahuje users/{uid}, takže sameCompany nejde použít).
     * Dokument musí mít vlastníka = aktuální uživatel.
     */
    function isNewCompanyOwnedByRequester() {
      return signedIn() &&
        request.resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.ownerId == request.auth.uid;
    }

    /** Zaměstnanec (ne vlastník/admin/manažer/účetní) může zapisovat vlastní výkaz práce. */
    function canLogOwnWorkTime() {
      return hasUser() && ownEmployeeId() != null && !isPrivileged();
    }

    /** Zakázka pro výkaz práce — assignedWorklogJobIds nebo legacy assignedJobIds. */
    function jobAssignedForWorklog(companyId, jobId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(ownEmployeeId());
      return exists(empRef) && (
        ('assignedWorklogJobIds' in get(empRef).data && jobId in get(empRef).data.assignedWorklogJobIds) ||
        ('assignedJobIds' in get(empRef).data && jobId in get(empRef).data.assignedJobIds)
      );
    }

    /** Alias pro starší název v pravidlech create výkazu. */
    function jobAssignedToEmployee(companyId, jobId) {
      return jobAssignedForWorklog(companyId, jobId);
    }

    /** Zakázka pro docházkový terminál (vlastní zaměstnanec). */
    function jobAssignedForTerminal(companyId, jobId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(ownEmployeeId());
      return exists(empRef) &&
        'assignedTerminalJobIds' in get(empRef).data &&
        jobId in get(empRef).data.assignedTerminalJobIds;
    }

    function jobAssignedForTerminalToEmployee(companyId, empId, jobId) {
      let empRef = /databases/$(database)/documents/companies/$(companyId)/employees/$(empId);
      return exists(empRef) &&
        'assignedTerminalJobIds' in get(empRef).data &&
        jobId in get(empRef).data.assignedTerminalJobIds;
    }

    /** Pokud je u docházky vyplněno jobId, musí být přiřazeno pro terminál danému zaměstnanci. */
    function attendanceJobValid(companyId) {
      return !('jobId' in request.resource.data) ||
        request.resource.data.jobId == null ||
        (request.resource.data.jobId is string && request.resource.data.jobId.size() > 0 &&
          jobAssignedForTerminalToEmployee(companyId, request.resource.data.employeeId, request.resource.data.jobId));
    }

    function workBlockOwnPending() {
      return resource.data.employeeId == ownEmployeeId() &&
        resource.data.authUserId == request.auth.uid &&
        (resource.data.reviewStatus == 'pending' || resource.data.reviewStatus == 'rejected');
    }

    /** Úprava výkazu zaměstnancem — nesmí měnit schvalovací pole; zakázka musí být přiřazená. */
    function employeeWorkBlockUpdateValid(companyId) {
      return request.resource.data.employeeId == resource.data.employeeId &&
        request.resource.data.authUserId == resource.data.authUserId &&
        request.resource.data.companyId == resource.data.companyId &&
        request.resource.data.reviewStatus == resource.data.reviewStatus &&
        request.resource.data.jobId is string &&
        jobAssignedForWorklog(companyId, request.resource.data.jobId) &&
        request.resource.data.adminNote == resource.data.adminNote &&
        request.resource.data.adjustmentReason == resource.data.adjustmentReason &&
        (!('reviewedBy' in resource.data) ||
          request.resource.data.reviewedBy == resource.data.reviewedBy) &&
        (!('reviewedAt' in resource.data) ||
          request.resource.data.reviewedAt == resource.data.reviewedAt) &&
        (
          (!('description_translated' in request.resource.data) && !('description_translated' in resource.data)) ||
          request.resource.data.description_translated == resource.data.description_translated
        );
    }

    /** Kiosk terminál po custom tokenu (claim terminalAccess + companyId). */
    function terminalCompanyMatches(companyId) {
      return request.auth != null &&
        request.auth.token.terminalAccess == true &&
        request.auth.token.companyId == companyId;
    }

    // --- Uživatelské profily (klientská aplikace) ---
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;

      match /{subcollection}/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    // --- Odkazy na tablet terminál (pouze Admin SDK) ---
    match /terminalLinks/{tokenId} {
      allow read, write: if false;
    }

    // --- Firma ---
    match /companies/{companyId} {
      allow read: if (signedIn() && sameCompany(companyId)) || terminalCompanyMatches(companyId);
      allow create: if isNewCompanyOwnedByRequester();
      allow update, delete: if signedIn() && sameCompany(companyId) && isPrivileged();

      match /employees/{empId} {
        allow read: if (signedIn() && sameCompany(companyId)) || terminalCompanyMatches(companyId);
        allow write: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      match /work_time_blocks/{bid} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() ||
            (canLogOwnWorkTime() && resource.data.employeeId == ownEmployeeId()));
        allow create: if signedIn() && sameCompany(companyId) &&
          canLogOwnWorkTime() &&
          request.resource.data.authUserId == request.auth.uid &&
          request.resource.data.employeeId == ownEmployeeId() &&
          request.resource.data.jobId is string &&
          request.resource.data.jobId.size() > 0 &&
          jobAssignedToEmployee(companyId, request.resource.data.jobId) &&
          request.resource.data.reviewStatus == 'pending' &&
          (!('description_translated' in request.resource.data) ||
            request.resource.data.description_translated == null) &&
          (!('language' in request.resource.data) ||
            request.resource.data.language in ['cs', 'ua']);
        allow update: if signedIn() && sameCompany(companyId) && (
          isPrivileged() ||
          (canLogOwnWorkTime() && workBlockOwnPending() && employeeWorkBlockUpdateValid(companyId))
        );
        allow delete: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || workBlockEmployeeCanSelfDelete());
      }

      match /jobs/{jobId} {
        allow read: if terminalCompanyMatches(companyId) ||
          (signedIn() && sameCompany(companyId) &&
            (isPrivileged() || (canLogOwnWorkTime() && (jobAssignedForWorklog(companyId, jobId) || jobAssignedForTerminal(companyId, jobId)))));
        allow write: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /** Plánovaná zaměření před zakázkou: companies/{companyId}/measurements/{measurementId} */
      match /measurements/{measurementId} {
        allow read, write: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      /**
       * Zálohy / výplaty: companies/{companyId}/advances/{advanceId}
       * Pole: amount (number), date (string), employeeId, companyId, note, status (paid|unpaid),
       * createdAt, updatedAt, createdBy (uid).
       * Zaměstnanec čte jen své záznamy, správa jen isPrivileged().
       */
      match /advances/{advanceId} {
        allow read: if signedIn() && sameCompany(companyId) &&
          (isPrivileged() || resource.data.employeeId == ownEmployeeId());
        allow create: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.companyId == companyId &&
          request.resource.data.employeeId is string &&
          request.resource.data.amount is number &&
          request.resource.data.status in ['paid', 'unpaid'];
        allow update, delete: if signedIn() && sameCompany(companyId) && isPrivileged();
      }

      match /attendance/{documentId} {
        allow read: if terminalCompanyMatches(companyId) || (signedIn() && sameCompany(companyId));
        allow create: if (terminalCompanyMatches(companyId) || (signedIn() && sameCompany(companyId))) && attendanceJobValid(companyId);
        allow update, delete: if terminalCompanyMatches(companyId) || (signedIn() && sameCompany(companyId));
      }

      /** Chat zaměstnanec ↔ administrace: companies/{companyId}/chat/{messageId} */
      match /chat/{messageId} {
        allow read: if signedIn() && sameCompany(companyId);
        allow create: if signedIn() && sameCompany(companyId) &&
          request.resource.data.companyId == companyId &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 8000 &&
          request.resource.data.read == false &&
          request.resource.data.senderRole in ['employee', 'admin'] &&
          (
            (request.resource.data.senderRole == 'employee' && canLogOwnWorkTime()) ||
            (request.resource.data.senderRole == 'admin' && isPrivileged())
          );
        allow update: if signedIn() && sameCompany(companyId) && isPrivileged() &&
          request.resource.data.senderId == resource.data.senderId &&
          request.resource.data.companyId == resource.data.companyId &&
          request.resource.data.text == resource.data.text &&
          request.resource.data.senderRole == resource.data.senderRole &&
          request.resource.data.read is bool &&
          resource.data.read == false &&
          request.resource.data.read == true;
        allow delete: if false;
      }

      // Vše ostatní pod firmou (zakázky, podkolekce, …) — pouze privilegované role.
      // Zaměstnanec se sem nedostane (frontend redirect + tyto pravidla).
      match /{document=**} {
        allow read, write: if signedIn() && sameCompany(companyId) && isPrivileged();
      }
    }

    match /contractTemplates/{tid} {
      allow read: if signedIn() &&
        resource.data.companyId == userCompanyId();
      allow create: if signedIn() &&
        request.resource.data.companyId == userCompanyId() &&
        isPrivileged();
      allow update, delete: if signedIn() &&
        resource.data.companyId == userCompanyId() &&
        isPrivileged();
    }

    match /platform_invoices/{id} {
      allow read, write: if isSuperAdminFirebase();
    }

    match /organizations/{orgId} {
      allow read, update: if signedIn();
    }

    match /{collectionName}/{orgId} {
      allow read, update: if signedIn() && collectionName == 'společnosti';
      /** Registrace z /register — stejný dokument jako companies/{companyId}, vlastník = auth uid. */
      allow create: if signedIn() &&
        collectionName == 'společnosti' &&
        isNewCompanyOwnedByRequester();
    }

    match /superadmins/{id} {
      allow read, write: if false;
    }
  }
}
