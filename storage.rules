rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    /**
     * Zákazník portálu (users.role == customer) smí číst soubory zakázky přes SDK,
     * ale nesmí je mazat ani nahrávat — to dříve umožňovalo „allow write: auth != null“.
     */
    function storageUserDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }
    function hasStorageUser() {
      return request.auth != null && firestore.exists(storageUserDocPath());
    }
    function storageUserDoc() {
      return hasStorageUser() ? firestore.get(storageUserDocPath()).data : null;
    }
    function storageUserRole() {
      return hasStorageUser() ? storageUserDoc().role : null;
    }
    function storageSameCompany(companyId) {
      return hasStorageUser() && storageUserDoc().companyId == companyId;
    }
    function storageIsSuperAdmin() {
      return hasStorageUser() &&
        ('globalRoles' in storageUserDoc()) &&
        (storageUserDoc().globalRoles is list) &&
        ('super_admin' in storageUserDoc().globalRoles);
    }
    function storageIsPrivileged() {
      return storageIsSuperAdmin() || storageUserRole() in ['owner', 'admin', 'manager', 'accountant'];
    }
    function storageFolderAllowEmployeeUpload(companyId, jobId, folderId) {
      let fp = /databases/(default)/documents/companies/$(companyId)/jobs/$(jobId)/folders/$(folderId);
      return firestore.exists(fp) && (
        firestore.get(fp).data.allowEmployeeUpload == true ||
        /** Legacy (zpětná kompatibilita) */
        firestore.get(fp).data.employeeUploadAllowed == true
      );
    }

    /** Zaměstnanec přiřazen k zakázce — nahrávání řídí příznaky konkrétní složky. */
    function storageJobMemberAssigned(companyId, jobId) {
      let eid = storageUserDoc().employeeId;
      let mp = /databases/(default)/documents/companies/$(companyId)/jobs/$(jobId)/jobMembers/$(eid);
      return eid is string && eid.size() > 0 && firestore.exists(mp);
    }

    function storageJobMemberFullInternal(companyId, jobId) {
      let eid = storageUserDoc().employeeId;
      let mp = /databases/(default)/documents/companies/$(companyId)/jobs/$(jobId)/jobMembers/$(eid);
      return eid is string &&
        eid.size() > 0 &&
        firestore.exists(mp) &&
        'accessMode' in firestore.get(mp).data &&
        firestore.get(mp).data.accessMode == 'full_internal';
    }

    /** Zápis médií u zakázky (náklady / staré job-photos) — dříve chybějící funkce v pravidlech. */
    function storageJobMediaWriteOk() {
      return request.auth != null;
    }

    function storageJobCompanyWriteOk(companyId) {
      return request.auth != null && storageSameCompany(companyId);
    }

    // Profilové fotky: pouze vlastní složka podle UID
    match /profile_images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * Fotodokumentace zakázek — kanonická cesta (klient):
     * `companies/{companyId}/jobs/{jobId}/photos/...`
     */
    match /companies/{companyId}/jobs/{jobId}/photos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // beze změny (nezpřísňujeme mimo požadavek)
    }

    /** Obrázky průběhu zakázky pro klientský portál (slider na profilu zákazníka). */
    match /companies/{companyId}/jobs/{jobId}/customer-progress/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // beze změny (nezpřísňujeme mimo požadavek)
    }

    /** Složky a obrázky v nich — stejná úroveň oprávnění jako fotky zakázky. */
    match /companies/{companyId}/jobs/{jobId}/folders/{folderId}/images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && storageSameCompany(companyId) && (
        storageIsPrivileged() ||
        (
          storageUserRole() == 'employee' &&
          storageFolderAllowEmployeeUpload(companyId, jobId, folderId) &&
          (
            storageJobMemberFullInternal(companyId, jobId) ||
            storageJobMemberAssigned(companyId, jobId)
          )
        )
      );
    }

    /** PDF výrobních podkladů nahrané z portálu výroby. */
    match /companies/{companyId}/jobs/{jobId}/productionSheets/{allPaths=**} {
      allow read: if request.auth != null && storageSameCompany(companyId);
      allow write: if storageJobCompanyWriteOk(companyId);
    }

    /** Nářezový plánek — Excel/CSV (binární soubor se vzorci). */
    match /companies/{companyId}/jobs/{jobId}/cuttingPlanExcel/{allPaths=**} {
      allow read: if request.auth != null && storageSameCompany(companyId) && storageUserRole() != 'customer';
      allow write: if request.auth != null && storageSameCompany(companyId) && (
        storageIsSuperAdmin() || storageUserRole() in ['owner', 'admin']
      );
      allow delete: if request.auth != null && storageSameCompany(companyId) && (
        storageIsSuperAdmin() || storageUserRole() in ['owner', 'admin']
      );
    }

    /** PDF rychlých objednávek — zápis jen přes Admin SDK (server); čtení firma. */
    match /companies/{companyId}/jobs/{jobId}/materialOrderPdfExports/{allPaths=**} {
      allow read: if request.auth != null && storageSameCompany(companyId);
      allow write: if false;
    }

    /** Přílohy nákladů zakázky (foto / PDF). */
    match /companies/{companyId}/jobs/{jobId}/expenses/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if storageJobMediaWriteOk();
    }

    /**
     * Starší cesta (zpětná kompatibilita pro již nahrané soubory).
     */
    match /job-photos/{companyId}/{jobId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if storageJobMediaWriteOk();
    }

    /** Logo organizace pro tisk / PDF dokladů (faktury). */
    match /companies/{companyId}/branding/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Přílohy výrobních záznamů (PDF, foto, dokumenty). */
    match /companies/{companyId}/production/{productionId}/attachments/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Obrázky skladových položek. */
    match /companies/{companyId}/inventory/{itemId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Knihovna příloh k e-mailovým nabídkám. */
    match /companies/{companyId}/inquiry-offer-library/{allPaths=**} {
      allow read: if request.auth != null && storageSameCompany(companyId);
      allow write: if request.auth != null && storageSameCompany(companyId) && storageIsPrivileged();
    }

    /** Jednorázové uploady příloh při sestavování nabídky. */
    match /companies/{companyId}/inquiry-offer-uploads/{allPaths=**} {
      allow read: if request.auth != null && storageSameCompany(companyId);
      allow write: if request.auth != null && storageSameCompany(companyId) && (
        storageIsPrivileged() ||
        storageUserRole() in ['owner', 'admin', 'manager', 'accountant']
      );
    }

    /**
     * Dokumenty zaměstnanců (PDF, fotky, Word…):
     * companies/{companyId}/employees/{employeeId}/documents/{documentId}/...
     *
     * - Admin/privilegované role: read/write
     * - Zaměstnanec: read/write jen do své složky (typicky podpisy / doplňující soubory),
     *   mazání na úložišti se řeší přes Firestore delete (admin-only) nebo API.
     */
    match /companies/{companyId}/employees/{employeeId}/documents/{documentId}/{allPaths=**} {
      allow read: if request.auth != null && storageSameCompany(companyId) && (
        storageIsPrivileged() || storageUserDoc().employeeId == employeeId
      );
      allow write: if request.auth != null && storageSameCompany(companyId) && (
        storageIsPrivileged() || storageUserDoc().employeeId == employeeId
      );
    }

    /** Foto zaměření (anotované i originál) — pod ID dokumentu v Firestore. */
    match /companies/{companyId}/measurement_photos/{photoDocId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /**
     * Veřejná úvodní stránka — hero obrázky a promo video (zápis jen přes Admin SDK).
     */
    match /platform/landing/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
