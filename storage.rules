rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profilové fotky: pouze vlastní složka podle UID
    match /profile_images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * Fotodokumentace zakázek (klient: `job-photos/{companyId}/{jobId}/...`).
     * Firestore stále určuje, kdo může zapisovat metadata; Storage zde vyžaduje přihlášení.
     * Přísnější vazbu na firmu lze doplnit přes custom claim `companyId` na ID tokenu.
     */
    match /job-photos/{companyId}/{jobId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
