rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profilové fotky: pouze vlastní složka podle UID
    match /profile_images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * Fotodokumentace zakázek — kanonická cesta (klient):
     * `companies/{companyId}/jobs/{jobId}/photos/...`
     */
    match /companies/{companyId}/jobs/{jobId}/photos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Složky a obrázky v nich — stejná úroveň oprávnění jako fotky zakázky. */
    match /companies/{companyId}/jobs/{jobId}/folders/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Přílohy nákladů zakázky (foto / PDF). */
    match /companies/{companyId}/jobs/{jobId}/expenses/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /**
     * Starší cesta (zpětná kompatibilita pro již nahrané soubory).
     */
    match /job-photos/{companyId}/{jobId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Logo organizace pro tisk / PDF dokladů (faktury). */
    match /companies/{companyId}/branding/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Přílohy výrobních záznamů (PDF, foto, dokumenty). */
    match /companies/{companyId}/production/{productionId}/attachments/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Obrázky skladových položek. */
    match /companies/{companyId}/inventory/{itemId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /** Foto zaměření (anotované i originál) — pod ID dokumentu v Firestore. */
    match /companies/{companyId}/measurement_photos/{photoDocId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
